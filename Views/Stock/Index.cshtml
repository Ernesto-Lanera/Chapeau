@model IEnumerable<Chapeau.Models.MenuItem>

@{
	ViewData["Title"] = "VoorraadBeheer";

	var categories = ViewBag.Categories as IEnumerable<Chapeau.Models.Category>;

	if (categories == null)
	{
		categories = ViewBag.AllCategories as IEnumerable<Chapeau.Models.Category>;
	}

	if (categories == null)
	{
		categories = Enumerable.Empty<Chapeau.Models.Category>();
	}

	int? selectedCardId = null;
	int? selectedCategoryId = null;

	if (ViewBag.SelectedCardId != null)
	{
		selectedCardId = Convert.ToInt32(ViewBag.SelectedCardId);
	}

	if (ViewBag.SelectedCategoryId != null)
	{
		selectedCategoryId = Convert.ToInt32(ViewBag.SelectedCategoryId);
	}
}

<div class="page-content">

	@await Component.InvokeAsync("StockHeader")

	@await Component.InvokeAsync("StockFilter", new {
		categories = categories,
		selectedCardId = selectedCardId,
		selectedCategoryId = selectedCategoryId
	})

	@if (TempData["FlashError"] != null)
	{
		<div class="alert alert-danger">
			<strong>Er ging iets mis</strong>
			<ul>
				@foreach (var error in TempData["FlashError"].ToString()!.Split('\n'))
				{
					if (!string.IsNullOrWhiteSpace(error))
					{
						<li>@error</li>
					}
				}
			</ul>
		</div>
	}

	@if (TempData["FlashSuccess"] != null)
	{
		<div class="alert alert-success">
			@TempData["FlashSuccess"]
		</div>
	}

	@await Component.InvokeAsync("StockTable", new {
		menuItems = Model,
		categories = categories,
		selectedCardId = selectedCardId,
		selectedCategoryId = selectedCategoryId
	})

</div>
