@model Chapeau.Components.ManageMenuCreateForm.ManageMenuCreateFormModel

<link rel="stylesheet" href="~/css/components/manage-menu/manage-menu-forms.css" />

<div class="form-card">
    <h3>Nieuw Menu Item</h3>

    <form method="post"
          action="@Url.Action("Create", "ManageMenu")"
          enctype="multipart/form-data"
          class="menu-item-form preserve-scroll-form">

        @Html.AntiForgeryToken()

        <div class="form-group">
            <select id="createMenuCardSelect" name="MenuCardID" class="form-select" required="required">
                <option value="">-- Selecteer kaart --</option>

                @foreach (var card in Model.MenuCards)
                {
                    if (Model.SelectedCardId.HasValue && card.Value == Model.SelectedCardId.Value.ToString())
                    {
                        <option value="@card.Value" selected="selected">@card.Text</option>
                    }
                    else
                    {
                        <option value="@card.Value">@card.Text</option>
                    }
                }
            </select>
        </div>

        <div class="form-group">
            <input type="text"
                   name="Name"
                   class="form-control"
                   placeholder="Naam"
                   required="required" />
        </div>

        <div class="form-group">
            <input type="text"
                   name="RetailPrice"
                   class="form-control"
                   placeholder="Prijs (12,50)"
                   required="required" />
        </div>

        <div class="form-group">
            <input type="number"
                   name="Stock"
                   class="form-control"
                   placeholder="Voorraad"
                   value="0"
                   min="0"
                   required="required" />
        </div>

        <div class="form-group">
            <select id="createCategorySelect" name="CategoryID" class="form-select" required="required">
                <option value="">-- Selecteer categorie --</option>

                @foreach (var category in Model.FormCategories)
                {
                    <option value="@category.CategoryID"
                            data-cardid="@category.MenuCardID">
                        @GetCategoryDisplayName(category)
                    </option>
                }
            </select>
        </div>

        <div class="form-group">
            <label for="createImageUpload" class="form-label">Afbeelding optioneel</label>

            <input type="file"
                   id="createImageUpload"
                   name="imageFile"
                   accept="image/*"
                   class="form-control" />

            <small class="form-text text-muted">JPG, PNG, WebP max. 10MB</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary preserve-scroll">
                Toevoegen
            </button>

            <a href="@Url.Action("Index", "ManageMenu", new { cardId = Model.SelectedCardId, categoryId = Model.SelectedCategoryId })"
               class="btn btn-secondary preserve-scroll">
                Annuleren
            </a>
        </div>
    </form>
</div>

<script src="~/js/manage-menu-form-filter.js"></script>

@functions {
    string GetMenuCardName(int menuCardId)
    {
        return menuCardId switch
        {
            1 => "Lunch",
            2 => "Diner",
            3 => "Dranken",
            _ => "Onbekend"
        };
    }

    string GetCategoryDisplayName(Chapeau.Models.Category category)
    {
        if (category.MenuCardID == 1 || category.MenuCardID == 2)
        {
            return $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
        }

        return category.Name;
    }
}
