@model Chapeau.Components.ManageMenuTable.ManageMenuTableModel

<link rel="stylesheet" href="~/css/components/manage-menu/manage-menu-table.css" />

<div class="menu-table-card">
    <table class="menu-table">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Prijs</th>
                <th>Kaart</th>
                <th>Categorie</th>
                <th>Status</th>
                <th>Acties</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.MenuItems)
            {
                var category = Model.AllCategories.FirstOrDefault(c => c.CategoryID == item.CategoryID);
                string categoryName = category != null ? GetCategoryDisplayName(category) : "-";
                string cardName = category != null ? GetMenuCardName(category.MenuCardID) : "-";
                string rowClass = item.IsActive ? "" : "inactive-row";

                <tr class="@rowClass">
                    <td>@item.Name</td>
                    <td>€ @item.RetailPrice.ToString("F2", new System.Globalization.CultureInfo("nl-NL"))</td>
                    <td>@cardName</td>
                    <td>@categoryName</td>

                    <td>
                        @if (item.IsActive)
                        {
                            <span class="status-badge status-active">Actief</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Inactief</span>
                        }
                    </td>

                    <td>
                        <div class="action-cell">
                            <a href="@Url.Action("Index", "ManageMenu", new { editId = item.MenuItemID, cardId = Model.SelectedCardId, categoryId = Model.SelectedCategoryId })"
                               class="action-icon action-edit preserve-scroll"
                               title="Bewerken">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke="currentColor">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M19.5 7.125L16.875 4.5" />
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                </svg>
                            </a>

                            <form method="post"
                                  action="@Url.Action("ToggleActive", "ManageMenu")"
                                  class="inline-action-form preserve-scroll-form">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@item.MenuItemID" />
                                <input type="hidden" name="cardId" value="@Model.SelectedCardId" />
                                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />

                                @if (item.IsActive)
                                {
                                    <input type="hidden" name="active" value="false" />

                                    <button type="submit"
                                            class="action-icon action-inactive preserve-scroll"
                                            title="Deactiveren">
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                             fill="none"
                                             viewBox="0 0 24 24"
                                             stroke="currentColor">
                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  d="M12 3v9" />
                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                        </svg>
                                    </button>
                                }
                                else
                                {
                                    <input type="hidden" name="active" value="true" />

                                    <button type="submit"
                                            class="action-icon action-active preserve-scroll"
                                            title="Activeren">
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                             fill="none"
                                             viewBox="0 0 24 24"
                                             stroke="currentColor">
                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  d="M12 3v9" />
                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                        </svg>
                                    </button>
                                }
                            </form>
                        </div>
                    </td>
                </tr>

                @if (Model.EditItem != null && Model.EditItem.MenuItemID == item.MenuItemID)
                {
                    <tr class="inline-edit-row">
                        <td colspan="6">
                            @await Component.InvokeAsync("ManageMenuEditForm", new {
                                editItem = Model.EditItem,
                                menuCards = ViewBag.MenuCards,
                                formCategories = ViewBag.Categories,
                                selectedMenuCardId = ViewBag.SelectedMenuCardId,
                                selectedCardId = Model.SelectedCardId,
                                selectedCategoryId = Model.SelectedCategoryId
                            })
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@functions {
    string GetMenuCardName(int menuCardId)
    {
        return menuCardId switch
        {
            1 => "Lunch",
            2 => "Diner",
            3 => "Dranken",
            _ => "Onbekend"
        };
    }

    string GetCategoryDisplayName(Chapeau.Models.Category category)
    {
        if (category.MenuCardID == 1 || category.MenuCardID == 2)
        {
            return $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
        }

        return category.Name;
    }
}
