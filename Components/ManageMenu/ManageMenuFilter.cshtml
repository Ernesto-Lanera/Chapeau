@model Chapeau.Components.ManageMenuFilter.ManageMenuFilterModel

<link rel="stylesheet" href="~/css/components/manage-menu/manage-menu-filters.css" />

<form method="get"
      action="@Url.Action("Index", "ManageMenu")"
      class="preserve-scroll-form">
    <div class="filter-row">
        <div class="filter-group">
            <label>Kaart</label>
            <select name="cardId" onchange="this.form.submit()">
                <option value="">Alle</option>

                @foreach (var card in Model.MenuCards)
                {
                    if (Model.SelectedCardId.HasValue && Model.SelectedCardId.Value.ToString() == card.Value)
                    {
                        <option value="@card.Value" selected="selected">@card.Text</option>
                    }
                    else
                    {
                        <option value="@card.Value">@card.Text</option>
                    }
                }
            </select>
        </div>

        <div class="filter-group">
            <label>Categorie</label>
            <select name="categoryId" onchange="this.form.submit()">
                <option value="">Alle</option>

                @foreach (var category in Model.FilterCategories)
                {
                    if (!Model.SelectedCardId.HasValue || category.MenuCardID == Model.SelectedCardId.Value)
                    {
                        if (Model.SelectedCategoryId.HasValue && Model.SelectedCategoryId.Value == category.CategoryID)
                        {
                            <option value="@category.CategoryID" selected="selected">
                                @GetCategoryDisplayName(category)
                            </option>
                        }
                        else
                        {
                            <option value="@category.CategoryID">
                                @GetCategoryDisplayName(category)
                            </option>
                        }
                    }
                }
            </select>
        </div>
    </div>
</form>

@functions {
    string GetMenuCardName(int menuCardId)
    {
        return menuCardId switch
        {
            1 => "Lunch",
            2 => "Diner",
            3 => "Dranken",
            _ => "Onbekend"
        };
    }

    string GetCategoryDisplayName(Chapeau.Models.Category category)
    {
        if (category.MenuCardID == 1 || category.MenuCardID == 2)
        {
            return $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
        }

        return category.Name;
    }
}
