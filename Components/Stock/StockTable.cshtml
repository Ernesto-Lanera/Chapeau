@model Chapeau.Components.StockTable.StockTableModel

<link rel="stylesheet" href="~/css/components/stock/stock-table.css" />

<div class="stock-summary-row">
    <span class="stock-pill danger">
        Uitverkocht: <span id="soldOutCount">@Model.MenuItems.Count(x => x.Stock == 0)</span> item(s)
    </span>

    <span class="stock-pill warn">
        Bijna op: <span id="almostOutCount">@Model.MenuItems.Count(x => x.Stock > 0 && x.Stock <= 10)</span> item(s)
    </span>
</div>

<div class="stock-table-card">
    <table class="stock-table" id="stockTable">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Kaart</th>
                <th>Categorie</th>
                <th>Voorraad</th>
                <th>Status</th>
                <th>Acties</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.MenuItems)
            {
                var itemCategory = item.Category;

                if (itemCategory == null)
                {
                    itemCategory = Model.Categories.FirstOrDefault(c => c.CategoryID == item.CategoryID);
                }

                string cardName = "-";
                string categoryName = "Onbekend";

                if (itemCategory != null)
                {
                    cardName = GetMenuCardName(itemCategory.MenuCardID);
                    categoryName = GetCategoryDisplayName(itemCategory);
                }

                string pillClass = "ok";
                string pillText = "Op voorraad";

                if (item.Stock == 0)
                {
                    pillClass = "danger";
                    pillText = "Uitverkocht";
                }
                else if (item.Stock <= 10)
                {
                    pillClass = "warn";
                    pillText = "Bijna op";
                }

                string rowClass = item.Stock == 0 ? "sold-out-row" : "";

                <tr class="@rowClass">
                    <td>@item.Name</td>
                    <td>@cardName</td>
                    <td>@categoryName</td>

                    <td>
                        <input class="stock-input stock-current"
                               type="number"
                               min="0"
                               value="@item.Stock" />
                    </td>

                    <td>
                        <span class="stock-pill @pillClass stock-status">
                            <span class="stock-status-text">@pillText</span>
                        </span>
                    </td>

                    <td>
                        <div class="qty-actions">
                            <form method="post"
                                  action="@Url.Action("Update", "Stock")"
                                  class="inline-stock-form stock-form">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@item.MenuItemID" />
                                <input type="hidden" name="newStock" class="stock-new" value="@item.Stock" />
                                <input type="hidden" name="cardId" value="@Model.SelectedCardId" />
                                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />

                                <button type="submit"
                                        class="stock-action-button stock-plus stock-delta"
                                        data-delta="10"
                                        title="+10">
                                    +10
                                </button>

                                <button type="submit"
                                        class="stock-action-button stock-minus stock-delta"
                                        data-delta="-1"
                                        title="-1">
                                    -1
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="~/js/stock-table.js"></script>

@functions {
    string GetMenuCardName(int menuCardId)
    {
        return menuCardId switch
        {
            1 => "Lunch",
            2 => "Diner",
            3 => "Dranken",
            _ => "-"
        };
    }

    string GetCategoryDisplayName(Chapeau.Models.Category category)
    {
        if (category.MenuCardID == 1 || category.MenuCardID == 2)
        {
            return $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
        }

        return category.Name;
    }
}
