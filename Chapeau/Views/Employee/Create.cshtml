@model Chapeau.Models.Employee

<h2>Add New Employee</h2>

<form method="post" action="@Url.Action("Create")">
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group mb-3">
        <label>Name</label>
        <input type="text" name="Name" value="@Model?.Name" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Role</label>
        <select name="RoleID" class="form-control" required>
            <option value="">-- Select a Role --</option>
            @{
                var roles = (System.Collections.Generic.IEnumerable<Chapeau.Models.Role>)ViewBag.Roles;
                foreach (var role in roles ?? Enumerable.Empty<Chapeau.Models.Role>())
                {
                    <option value="@role.RoleID" selected="@(Model?.RoleID == role.RoleID)">@role.RoleName</option>
                }
            }
        </select>
    </div>
    <div class="form-group mb-3">
        <label>Password</label>
        <input type="password" name="PasswordHash" class="form-control" required />
        <small class="form-text text-muted">Password will be securely hashed before storing in the database.</small>
        @Html.ValidationMessageFor(m => m.PasswordHash, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" name="IsActive" value="true" checked="@(Model?.IsActive ?? true)" /> Is Active
        </label>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
</form>