@model Chapeau.Models.Employee

<h2>Edit Employee</h2>

<form method="post" action="@Url.Action("Edit")">
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />

    <div class="form-group mb-3">
        <label>Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Role</label>
        <select name="Role" class="form-control" required>
            <option value="Manager" selected="@(Model.Role == Chapeau.Models.EmployeeRole.Manager)">Manager</option>
            <option value="Waiter" selected="@(Model.Role == Chapeau.Models.EmployeeRole.Waiter)">Waiter</option>
            <option value="Kitchen" selected="@(Model.Role == Chapeau.Models.EmployeeRole.Kitchen)">Kitchen</option>
        </select>
        @Html.ValidationMessageFor(m => m.Role, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Username / Employee Number</label>
        <input type="text" name="Username" value="@Model.Username" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Password Hash / PIN</label>
        <input type="text" name="PasswordHash" value="@Model.PasswordHash" class="form-control" required />
        @Html.ValidationMessageFor(m => m.PasswordHash, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") /> Is Active
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
</form>