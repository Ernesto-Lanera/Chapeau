@model Chapeau.Models.Employee

<h2>Medewerker bewerken</h2>

<form method="post" action="@Url.Action("Edit")">
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />

    <div class="form-group mb-3">
        <label>Naam</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Rol</label>
        <select name="RoleID" class="form-control" required>
            @{
                var roles = (System.Collections.Generic.IEnumerable<Chapeau.Models.Role>)ViewBag.Roles;
                foreach (var role in roles ?? Enumerable.Empty<Chapeau.Models.Role>())
                {
                    <option value="@role.RoleID" selected="@(Model.RoleID == role.RoleID)">@role.RoleName</option>
                }
            }
        </select>
    </div>
    <div class="form-group mb-3">
        <label>Wachtwoord</label>
        <input type="password" name="PasswordHash" class="form-control" placeholder="Wachtwoord" />
        @Html.ValidationMessageFor(m => m.PasswordHash, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") /> Actief
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Bijwerken</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Annuleren</a>
</form>