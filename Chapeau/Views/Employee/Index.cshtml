@model Chapeau.ViewModels.EmployeeManagementViewModel

@{
    ViewData["Title"] = "Medewerker Beheer";
}

<div class="page-content">
    <div class="page-title-row">
        <h2 class="page-title">Medewerkers Beheer</h2>
        @if (Model.ShowCreate)
        {
            <a asp-action="Index" class="btn-close-form preserve-scroll">Sluiten</a>
        }
        else
        {
            <a asp-action="Index" asp-route-showCreate="true" class="btn-new preserve-scroll">+ Nieuwe Medewerker</a>
        }
    </div>

    @if (Model.ShowCreate)
    {
        <partial name="_EmployeeForm" model="Model" />
    }

    <div class="employee-table-card">
        <table class="employee-table">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Rol</th>
                    <th>Status</th>
                    <th>Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in Model.Employees)
                {
                    <tr class="@(!employee.IsActive ? "inactive-row" : string.Empty)">
                        <td>@employee.Name</td>
                        <td>@employee.Role.RoleName</td>
                        <td>
                            <span class="status-badge @(employee.IsActive ? "status-active" : "status-inactive")">
                                @(employee.IsActive ? "Actief" : "Inactief")
                            </span>
                        </td>
                        <td>
                            <div class="action-cell">
                                <a asp-action="Index" asp-route-editId="@employee.EmployeeID"
                                   class="action-icon action-edit preserve-scroll" title="Bewerken">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 7.125L16.875 4.5" />
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                    </svg>
                                </a>
                                <form asp-action="ToggleActive" method="post" class="inline-action-form preserve-scroll-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@employee.EmployeeID" />
                                    @if (employee.IsActive)
                                    {
                                        <input type="hidden" name="active" value="false" />
                                        <button type="submit" class="action-icon action-inactive preserve-scroll" title="Deactiveren">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v9" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4l16 16" />
                                            </svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <input type="hidden" name="active" value="true" />
                                        <button type="submit" class="action-icon action-active preserve-scroll" title="Activeren">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v9" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                            </svg>
                                        </button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                    @if (Model.EditEmployee?.EmployeeID == employee.EmployeeID)
                    {
                        <tr class="edit-row">
                            <td colspan="4">
                                <partial name="_EmployeeForm" model="Model" />
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/employee.js" asp-append-version="true"></script>
}
