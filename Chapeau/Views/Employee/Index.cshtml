@model IEnumerable<Chapeau.Models.Employee>

@{
    ViewData["Title"] = "MedewerkerBeheer";

    var roles = ViewBag.Roles as IEnumerable<Chapeau.Models.Role>;

    if (roles == null)
    {
        roles = Enumerable.Empty<Chapeau.Models.Role>();
    }

    var roleNameById = roles.ToDictionary(r => r.RoleID, r => r.RoleName);

    var editEmployee = ViewBag.EditEmployee as Chapeau.Models.Employee;

    bool isEdit = editEmployee != null;
    bool showCreate = ViewBag.ShowCreate != null && (bool)ViewBag.ShowCreate;

    string? draftJson = TempData["NewEmployeeDraft"] as string;
    string draftName = "";
    int draftRoleId = 0;

    if (!string.IsNullOrWhiteSpace(draftJson))
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(draftJson);
            var root = doc.RootElement;

            if (root.TryGetProperty("Name", out var nameEl))
            {
                draftName = nameEl.GetString() ?? "";
            }

            if (root.TryGetProperty("RoleID", out var roleEl) && roleEl.TryGetInt32(out var rid))
            {
                draftRoleId = rid;
            }
        }
        catch
        {
        }
    }
}

<style>
    body {
        background-color: #f8fafc;
    }

    .page-content {
        padding: 28px 24px;
    }

    .page-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .btn-new {
        background-color: #16a34a;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-new:hover {
            background-color: #15803d;
            color: white;
        }

    .btn-close-form {
        background-color: #6b7280;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-close-form:hover {
            background-color: #4b5563;
            color: white;
        }

    .employee-table-card {
        background-color: white;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
    }

    .employee-table {
        width: 100%;
        margin: 0;
        border-collapse: collapse;
    }

        .employee-table thead {
            background-color: #f9fafb;
        }

        .employee-table th {
            padding: 16px 22px;
            font-size: 14px;
            font-weight: 700;
            color: #111827;
            text-align: left;
        }

        .employee-table td {
            padding: 17px 22px;
            border-top: 1px solid #f1f5f9;
            color: #374151;
            font-size: 14px;
            vertical-align: middle;
        }

        .employee-table tbody tr:hover {
            background-color: #f9fafb;
        }

    .inactive-row td {
        color: #6b7280;
        background-color: #f3f4f6;
    }

    .inactive-row:hover td {
        background-color: #f3f4f6;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 9px;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 500;
    }

    .status-active {
        background-color: #dcfce7;
        color: #166534;
    }

    .status-inactive {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .action-cell {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .action-icon {
        border: none;
        background: transparent;
        padding: 0;
        width: 22px;
        height: 22px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .action-icon svg {
            width: 18px;
            height: 18px;
            stroke-width: 2;
        }

    .action-edit {
        color: #2563eb;
    }

        .action-edit:hover {
            color: #1d4ed8;
        }

    .action-active {
        color: #22c55e;
    }

        .action-active:hover {
            color: #16a34a;
        }

    .action-inactive {
        color: #ef4444;
    }

        .action-inactive:hover {
            color: #dc2626;
        }

    .inline-action-form {
        display: inline;
        margin: 0;
        padding: 0;
    }

    .form-card {
        background-color: #eff6ff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        margin-bottom: 28px;
        padding: 24px;
    }

    .inline-edit-row td {
        background-color: #eff6ff;
        padding: 24px;
    }

    .inline-edit-card {
        background-color: #eff6ff;
        border-radius: 10px;
    }

        .form-card h3,
        .inline-edit-card h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 18px;
            color: #111827;
        }

    .employee-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

        .employee-form .form-group {
            margin-bottom: 0;
        }

        .employee-form input.form-control,
        .employee-form select.form-select {
            height: 48px;
            border-radius: 8px;
            border: 1px solid #d1d5db;
            background-color: #f8fbff;
            padding: 10px 16px;
            font-size: 15px;
            color: #111827;
            width: 100%;
        }

            .employee-form input.form-control:focus,
            .employee-form select.form-select:focus {
                border-color: #93c5fd;
                outline: none;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
            }

        .employee-form .form-actions {
            grid-column: 1 / 3;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-top: 12px;
        }

            .employee-form .form-actions button[type="submit"] {
                min-width: 110px;
                height: 46px;
                border-radius: 8px;
                font-weight: 700;
                background-color: #2563eb;
                border-color: #2563eb;
                color: white;
            }

                .employee-form .form-actions button[type="submit"]:hover {
                    background-color: #1d4ed8;
                    border-color: #1d4ed8;
                }

            .employee-form .form-actions a.btn-secondary {
                min-width: 110px;
                height: 46px;
                border-radius: 8px;
                font-weight: 700;
                background-color: #d1d5db;
                border-color: #d1d5db;
                color: #111827;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
            }

                .employee-form .form-actions a.btn-secondary:hover {
                    background-color: #c4c9d1;
                    border-color: #c4c9d1;
                    color: #111827;
                }

    @@media (max-width: 768px) {
        .employee-form {
            grid-template-columns: 1fr;
        }

            .employee-form .form-actions {
                grid-column: 1 / 2;
                flex-wrap: wrap;
            }
    }
</style>

<div class="page-content">
    <div class="page-title-row">
        <h2 class="page-title">Medewerkers Beheer</h2>

        @if (showCreate)
        {
            <a href="@Url.Action("Index", "Employee")"
                   class="btn-close-form preserve-scroll">
                Sluiten
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Employee", new { showCreate = true })"
                   class="btn-new preserve-scroll">
                + Nieuwe Medewerker
            </a>
        }
    </div>

    @if (showCreate)
    {
        <div class="form-card">
            <h3>Nieuwe Medewerker</h3>

            <form method="post"
                  action="@Url.Action("Create", "Employee")"
                  class="employee-form preserve-scroll-form">

                @Html.AntiForgeryToken()

                <div class="form-group">
                    <input type="text"
                           name="Name"
                           class="form-control"
                           placeholder="Naam"
                           value="@draftName"
                           required="required" />
                </div>

                <div class="form-group">
                    <input type="password"
                           name="Password"
                           class="form-control"
                           placeholder="Wachtwoord"
                           required="required" />
                </div>

                <div class="form-group">
                    <select name="RoleID" class="form-select" required="required">
                        <option value="">-- Selecteer rol --</option>

                        @foreach (var role in roles)
                        {
                            if (draftRoleId == role.RoleID)
                            {
                                <option value="@role.RoleID" selected="selected">@role.RoleName</option>
                            }
                            else
                            {
                                <option value="@role.RoleID">@role.RoleName</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary preserve-scroll">
                        Toevoegen
                    </button>

                    <a href="@Url.Action("Index", "Employee")"
                           class="btn btn-secondary preserve-scroll">
                        Annuleren
                    </a>
                </div>
            </form>
        </div>
    }

    <div class="employee-table-card">
        <table class="employee-table">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Gebruikersnaam</th>
                    <th>Rol</th>
                    <th>Status</th>
                    <th>Acties</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var employee in Model)
                {
                    var usernameBase = (employee.Name ?? "")
                        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                        .FirstOrDefault()?.ToLowerInvariant() ?? "user";

                    string username = $"{usernameBase}{employee.EmployeeID:000}";

                    string roleName = roleNameById.TryGetValue(employee.RoleID, out var rn)
                        ? rn
                        : employee.RoleID.ToString();

                    string rowClass = employee.IsActive ? "" : "inactive-row";

                    <tr class="@rowClass">
                        <td>@employee.Name</td>
                        <td>@username</td>
                        <td>@roleName</td>

                        <td>
                            @if (employee.IsActive)
                            {
                                <span class="status-badge status-active">Actief</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Inactief</span>
                            }
                        </td>

                        <td>
                            <div class="action-cell">
                                <a href="@Url.Action("Index", "Employee", new { editId = employee.EmployeeID })"
                                       class="action-icon action-edit preserve-scroll"
                                       title="Bewerken">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         fill="none"
                                         viewBox="0 0 24 24"
                                         stroke="currentColor">
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              d="M19.5 7.125L16.875 4.5" />
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              d="M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                    </svg>
                                </a>

                                <form method="post"
                                      action="@Url.Action("SetActive", "Employee")"
                                      class="inline-action-form preserve-scroll-form">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@employee.EmployeeID" />

                                    @if (employee.IsActive)
                                    {
                                        <input type="hidden" name="active" value="false" />

                                        <button type="submit"
                                                class="action-icon action-inactive preserve-scroll"
                                                title="Deactiveren">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 fill="none"
                                                 viewBox="0 0 24 24"
                                                 stroke="currentColor">
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      d="M12 3v9" />
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      d="M4 4l16 16" />
                                            </svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <input type="hidden" name="active" value="true" />

                                        <button type="submit"
                                                class="action-icon action-active preserve-scroll"
                                                title="Activeren">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 fill="none"
                                                 viewBox="0 0 24 24"
                                                 stroke="currentColor">
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      d="M12 3v9" />
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                            </svg>
                                        </button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>

                    @if (isEdit && editEmployee != null && editEmployee.EmployeeID == employee.EmployeeID)
                    {
                        <tr class="inline-edit-row">
                            <td colspan="5">
                                <div class="inline-edit-card">
                                    <h3>Medewerker Bewerken</h3>

                                    <form method="post"
                                          action="@Url.Action("Edit", "Employee")"
                                          class="employee-form preserve-scroll-form">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="EmployeeID" value="@editEmployee.EmployeeID" />

                                        <div class="form-group">
                                            <input type="text"
                                                   name="Name"
                                                   class="form-control"
                                                   placeholder="Naam"
                                                   value="@editEmployee.Name"
                                                   required="required" />
                                        </div>

                                        <div class="form-group">
                                            <input type="password"
                                                   name="Password"
                                                   class="form-control"
                                                   placeholder="Nieuw wachtwoord optioneel" />
                                        </div>

                                        <div class="form-group">
                                            <select name="RoleID" class="form-select" required="required">
                                                <option value="">-- Selecteer rol --</option>

                                                @foreach (var role in roles)
                                                {
                                                    if (editEmployee.RoleID == role.RoleID)
                                                    {
                                                        <option value="@role.RoleID" selected="selected">@role.RoleName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@role.RoleID">@role.RoleName</option>
                                                    }
                                                }
                                            </select>
                                        </div>

                                        <div class="form-actions">
                                            <button type="submit" class="btn btn-primary preserve-scroll">
                                                Bijwerken
                                            </button>

                                            <a href="@Url.Action("Index", "Employee")"
                                                   class="btn btn-secondary preserve-scroll">
                                                Annuleren
                                            </a>
                                        </div>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>