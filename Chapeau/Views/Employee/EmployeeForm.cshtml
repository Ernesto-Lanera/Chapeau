@model Chapeau.Models.Employee

@{
    bool isEdit = ViewBag.IsEdit != null && (bool)ViewBag.IsEdit;

    var roles = ViewBag.Roles as IEnumerable<Chapeau.Models.EmployeeRole>
        ?? Enumerable.Empty<Chapeau.Models.EmployeeRole>();

    string formAction = isEdit ? "Edit" : "Create";
    string buttonText = isEdit ? "Bijwerken" : "Toevoegen";
    string passwordPlaceholder = isEdit
        ? "Nieuw wachtwoord/pincode, leeg laten = behouden"
        : "Wachtwoord/pincode";
}

<form asp-controller="Employee"
      asp-action="@formAction"
      method="post"
      class="employee-form preserve-scroll-form">

    @Html.AntiForgeryToken()

    @if (isEdit)
    {
        <input type="hidden" asp-for="EmployeeID" />
        <input type="hidden" asp-for="IsActive" />
    }
    else
    {
        <input type="hidden" name="IsActive" value="true" />
    }

    <div class="employee-form-grid">
        <div class="form-group">
            <label asp-for="Name" class="form-label">Naam</label>

            <input asp-for="Name"
                   class="form-control"
                   placeholder="Bijvoorbeeld: Jan Jansen"
                   autocomplete="name"
                   required />

            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="PasswordHash" class="form-label">
                @(isEdit ? "Nieuw wachtwoord/pincode" : "Wachtwoord/pincode")
            </label>

            @if (isEdit)
            {
                <input type="password"
                       id="PasswordHash"
                       name="PasswordHash"
                       class="form-control"
                       placeholder="@passwordPlaceholder"
                       autocomplete="new-password" />
            }
            else
            {
                <input type="password"
                       id="PasswordHash"
                       name="PasswordHash"
                       class="form-control"
                       placeholder="@passwordPlaceholder"
                       autocomplete="new-password"
                       required />
            }

            <span asp-validation-for="PasswordHash" class="text-danger"></span>

            @if (isEdit)
            {
                <small class="form-text text-muted">
                    Laat dit veld leeg als het bestaande wachtwoord behouden moet blijven.
                </small>
            }
        </div>

        <div class="form-group">
            <label asp-for="RoleID" class="form-label">Rol</label>

            <select asp-for="RoleID" class="form-select" required>
                <option value="">-- Selecteer rol --</option>

                @foreach (var role in roles)
                {
                    <option value="@role.RoleID">
                        @role.RoleName
                    </option>
                }
            </select>

            <span asp-validation-for="RoleID" class="text-danger"></span>
        </div>

        <div class="employee-form-actions">
            <button type="submit" class="btn btn-primary">
                @buttonText
            </button>

            <a asp-controller="Employee"
               asp-action="Index"
               class="btn btn-secondary preserve-scroll">
                Annuleren
            </a>
        </div>
    </div>
</form>