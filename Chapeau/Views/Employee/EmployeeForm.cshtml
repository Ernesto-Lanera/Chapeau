@model Chapeau.Models.Employee

@{
    bool isEdit = false;

    if (ViewBag.IsEdit != null)
    {
        isEdit = (bool)ViewBag.IsEdit;
    }

    var roles = ViewBag.Roles as IEnumerable<Chapeau.Models.EmployeeRole>;

    if (roles == null)
    {
        roles = Enumerable.Empty<Chapeau.Models.EmployeeRole>();
    }

    string formAction = isEdit ? "Update" : "Create";
    string buttonText = isEdit ? "Bijwerken" : "Toevoegen";
    string buttonClass = "btn-primary";
}

<form method="post" action="@Url.Action(formAction, "Employee")">
    @if (isEdit)
    {
        <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />
        <input type="hidden" name="IsActive" value="@Model.IsActive.ToString().ToLower()" />
    }
    else
    {
        <input type="hidden" name="IsActive" value="true" />
    }

    <div class="row g-3">
        <div class="col-md-6">
            <input type="text"
                   name="Name"
                   value="@Model.Name"
                   class="form-control"
                   placeholder="Naam"
                   required="required" />

            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-6">
            @if (isEdit)
            {
                <input type="password"
                       name="PasswordHash"
                       value=""
                       class="form-control"
                       placeholder="Nieuw wachtwoord/pincode, leeg laten = behouden" />
            }
            else
            {
                <input type="password"
                       name="PasswordHash"
                       value=""
                       class="form-control"
                       placeholder="Wachtwoord/pincode"
                       required="required" />
            }

            @Html.ValidationMessageFor(m => m.PasswordHash, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-6">
            <select name="RoleID" class="form-select" required="required">
                <option value="">Kies rol</option>

                @foreach (var role in roles)
                {
                    if (Model.RoleID == role.RoleID)
                    {
                        <option value="@role.RoleID" selected="selected">@role.RoleName</option>
                    }
                    else
                    {
                        <option value="@role.RoleID">@role.RoleName</option>
                    }
                }
            </select>

            @Html.ValidationMessageFor(m => m.RoleID, "", new { @class = "text-danger" })
        </div>

        <div class="col-12">
            <button type="submit" class="btn @buttonClass">
                @buttonText
            </button>

            <a href="@Url.Action("Index", "Employee")" class="btn btn-secondary">
                Annuleren
            </a>
        </div>
    </div>
</form>