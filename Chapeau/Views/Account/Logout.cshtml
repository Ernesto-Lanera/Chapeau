@{
    ViewData["Title"] = "Logout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-body p-5 text-center">
                    <h1 class="card-title mb-4">Logout</h1>
                    <p class="lead mb-4">Are you sure you want to log out?</p>

                    <form method="post" asp-action="LogoutConfirmed" asp-controller="Account" class="d-inline">
                        <button type="submit" class="btn btn-danger me-2">Yes, log out</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
