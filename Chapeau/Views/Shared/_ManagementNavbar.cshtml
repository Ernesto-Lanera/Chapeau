@using Chapeau.Constants.Login
@using Chapeau.Extensions
@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
}

<nav class="navbar navbar-expand-lg navbar-dark app-navbar">
    <div class="container-fluid">
        <a class="navbar-brand fw-semibold app-brand"
           asp-area=""
           asp-controller="Home"
           asp-action="Index">
            Restaurant Chapeau
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNav"
                aria-controls="mainNav"
                aria-expanded="false"
                aria-label="Navigatie in-/uitschakelen">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Menu" ? "active" : string.Empty)" asp-controller="Menu" asp-action="Index">
                        Menu
                    </a>
                </li>
            </ul>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "ManageMenu" ? "active" : string.Empty)" asp-controller="ManageMenu" asp-action="Index">
                            <i class="bi bi-tools me-1"></i>Menubeheer
                        </a>
                    </li>
                    @if (User.HasPermission(PermissionConstants.ManageEmployees))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Employee" ? "active" : string.Empty)" asp-controller="Employee" asp-action="Index">
                                <i class="bi bi-person me-1"></i>Medewerkers
                            </a>
                        </li>
                    }
                    @if (User.HasPermission(PermissionConstants.ManageStock))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Stock" ? "active" : string.Empty)" asp-controller="Stock" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i>Voorraad
                            </a>
                        </li>
                    }
                    @if (User.HasPermission(PermissionConstants.ViewFinance))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Finance" ? "active" : string.Empty)" asp-controller="Finance" asp-action="Index">
                                <i class="bi bi-graph-up me-1"></i>Financieel
                            </a>
                        </li>
                    }
                    @if (User.HasPermission(PermissionConstants.ManageRoles))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "RolePermissions" ? "active" : string.Empty)" asp-controller="RolePermissions" asp-action="Index">
                                <i class="bi bi-shield-lock me-1"></i>Permissies
                            </a>
                        </li>
                    }

                    @* Operationele pagina's volgen de aangevinkte permissies, niet de vaste rol. *@
                    @if (User.HasPermission(PermissionConstants.TakeOrders))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Table" ? "active" : string.Empty)" asp-controller="Table" asp-action="Index">
                                Tafels
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Payment" ? "active" : string.Empty)" asp-controller="Payment" asp-action="Index">
                                Betaling
                            </a>
                        </li>
                    }
                    @if (User.HasPermission(PermissionConstants.PrepareFood))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Kitchen" ? "active" : string.Empty)" asp-controller="Kitchen" asp-action="Index">
                                Keuken
                            </a>
                        </li>
                    }
                    @if (User.HasPermission(PermissionConstants.PrepareDrinks))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Bar" ? "active" : string.Empty)" asp-controller="Bar" asp-action="Index">
                                Bar
                            </a>
                        </li>
                    }
                </ul>
            }

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                @await Component.InvokeAsync("LoginStatus")
            </ul>
        </div>
    </div>
</nav>
