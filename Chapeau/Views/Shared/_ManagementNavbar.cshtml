<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow app-navbar">
    <div class="container-fluid">

        <a class="navbar-brand fw-semibold app-brand"
           asp-area=""
           asp-controller="Home"
           asp-action="Index">
            Restaurant Chapeau
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNav"
                aria-controls="mainNav"
                aria-expanded="false"
                aria-label="Navigatie in-/uitschakelen">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">

            @if (User.Identity?.IsAuthenticated == true)
            {
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.HasClaim("Permission", "ManageMenuItems"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ManageMenu" ? "active" : "")" asp-controller="ManageMenu" asp-action="Index"><i class="bi bi-tools me-1"></i>Menubeheer</a></li>
                    }
                    @if (User.HasClaim("Permission", "ManageEmployees"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")" asp-controller="Employee" asp-action="Index"><i class="bi bi-person me-1"></i>Medewerkers</a></li>
                    }
                    @if (User.HasClaim("Permission", "ManageStock"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")" asp-controller="Stock" asp-action="Index"><i class="bi bi-box-seam me-1"></i>Voorraad</a></li>
                    }
                    @if (User.HasClaim("Permission", "ViewFinance") || User.HasClaim("Permission", "ViewReports"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Finance" ? "active" : "")" asp-controller="Finance" asp-action="Index"><i class="bi bi-graph-up me-1"></i>Financieel</a></li>
                    }
                    @if (User.HasClaim("Permission", "ManageRoles"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RolePermissions" ? "active" : "")" asp-controller="RolePermissions" asp-action="Index">Permissies</a></li>
                    }
                    @if (User.IsInRole("Bediening") || User.HasClaim("RoleID", "3"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Table" ? "active" : "")" asp-controller="Table" asp-action="Index">Tafels</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Menu" ? "active" : "")" asp-controller="Menu" asp-action="Index">Menu</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "active" : "")" asp-controller="Payment" asp-action="Index">Betaling</a></li>
                    }
                    @if (User.IsInRole("Keuken") || User.HasClaim("RoleID", "4"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Kitchen" ? "active" : "")" asp-controller="Kitchen" asp-action="Index">Keuken</a></li>
                    }
                    @if (User.IsInRole("Barman") || User.HasClaim("RoleID", "5"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bar" ? "active" : "")" asp-controller="Bar" asp-action="Index">Bar</a></li>
                    }
                </ul>
            }

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                @await Component.InvokeAsync("LoginStatus")
            </ul>
        </div>
    </div>
</nav>