<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Chapeau</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/manage-menu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/employee.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/stock.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/Chapeau.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow app-navbar">
            <div class="container-fluid">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center w-100 gap-2 gap-lg-4">
                    <a class="navbar-brand fw-semibold app-brand"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">
                        Restaurant Chapeau - Management System
                    </a>

                    <button class="navbar-toggler ms-auto"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#mainNav"
                            aria-controls="mainNav"
                            aria-expanded="false"
                            aria-label="Navigatie in-/uitschakelen">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Table" ? "active" : "")"
                               asp-area=""
                               asp-controller="Table"
                               asp-action="Index">
                                <i class="bi bi-grid-3x3-gap me-1"></i> Tafels
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ManageMenu" ? "active" : "")"
                               asp-area=""
                               asp-controller="ManageMenu"
                               asp-action="Index">
                                <i class="bi bi-tools me-1"></i> Menubeheer
                            </a>
                        </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")"
                                   asp-area=""
                                   asp-controller="Employee"
                                   asp-action="Index">
                                    <i class="bi bi-person me-1"></i>Medewerkers
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")"
                                   asp-area=""
                                   asp-controller="Stock"
                                   asp-action="Index">
                                    <i class="bi bi-box-seam me-1"></i>Voorraad
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Finance" ? "active" : "")"
                                   asp-area=""
                                   asp-controller="Finance"
                                   asp-action="Index">
                                    <i class="bi bi-graph-up me-1"></i>Financieel
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Menu" ? "active" : "")"
                                   asp-area=""
                                   asp-controller="Menu"
                                   asp-action="Index">
                                    <i class="bi bi-tools me-1"></i>Menu
                                </a>
                            </li>
                        </ul>
                        <ul class="navbar-nav ms-auto">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <li class="nav-item">
                                    <span class="nav-link">
                                        <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <partial name="_ToastMessage" />

    <div class="container-fluid app-container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Chapeau
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/manage-menu.js" asp-append-version="true"></script>
    <script src="~/js/employee.js" asp-append-version="true"></script>
    <script src="~/js/stock.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>