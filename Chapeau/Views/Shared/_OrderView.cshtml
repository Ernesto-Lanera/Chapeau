@model Chapeau.ViewModels.OrderViewModel

@using Chapeau.Emums

<div class="order-card">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <span class="table-label">Table</span>
            <span class="table-number">@Model.TableNumber</span>
        </div>
        <div class="text-end">
            <span class="order-time">@Model.OrderDate.ToString("HH:mm")</span>
            <span class="waiting-time">@Model.WaitingTimeDisplay</span>
        </div>
    </div>

    <div class="mb-2 d-flex justify-content-between align-items-center">
        <span class="status-badge">
            @((int)Model.OrderStatus == 5 || (int)Model.OrderStatus == 6
                ? "Ordered"
                : Model.OrderStatus.ToString())
        </span>
        @{
            var allItems = Model.CourseGroups != null && Model.CourseGroups.Any()
                ? Model.CourseGroups.SelectMany(g => g.Items).ToList()
                : Model.OrderItems;
            bool orderAllReady = allItems.All(i => i.Status == OrderStatus.ReadyToBeServed);
            bool orderAnyPreparing = allItems.Any(i => i.Status == OrderStatus.BeingPrepared);
        }
        @if (orderAllReady)
        {
            <form asp-action="MarkOrderReady" asp-controller="@Model.ControllerName" method="post">
                <input type="hidden" name="orderId" value="@Model.OrderID" />
                <button type="submit" class="btn btn-sm btn-success">✓ Order Ready</button>
            </form>
        }
        else if (orderAnyPreparing)
        {
            <form asp-action="ReadyAllItems" asp-controller="@Model.ControllerName" method="post">
                <input type="hidden" name="orderId" value="@Model.OrderID" />
                <button type="submit" class="btn btn-sm btn-warning">Ready All</button>
            </form>
        }
        else
        {
            <form asp-action="PrepareAllItems" asp-controller="@Model.ControllerName" method="post">
                <input type="hidden" name="orderId" value="@Model.OrderID" />
                <button type="submit" class="btn btn-sm btn-secondary">Prepare All</button>
            </form>
        }
    </div>

    <hr />

    @if (Model.CourseGroups != null && Model.CourseGroups.Any())
    {
        foreach (var group in Model.CourseGroups)
        {
            bool courseAllReady = group.Items.All(i => i.Status == OrderStatus.ReadyToBeServed);
            bool courseAnyPreparing = group.Items.Any(i => i.Status == OrderStatus.BeingPrepared);
            int courseValue = (int)group.Course;

            <div class="d-flex justify-content-between align-items-center mb-1">
                <h6 class="mb-0">@group.Course</h6>
                @if (courseAllReady)
                {
                    <span class="btn btn-sm btn-success disabled">✓</span>
                }
                else if (courseAnyPreparing)
                {
                    <form asp-action="ReadyAllItems" asp-controller="@Model.ControllerName" method="post">
                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                        <input type="hidden" name="course" value="@courseValue" />
                        <button type="submit" class="btn btn-sm btn-warning">Ready All</button>
                    </form>
                }
                else
                {
                    <form asp-action="PrepareAllItems" asp-controller="@Model.ControllerName" method="post">
                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                        <input type="hidden" name="course" value="@courseValue" />
                        <button type="submit" class="btn btn-sm btn-secondary">Prepare All</button>
                    </form>
                }
            </div>

            foreach (var item in group.Items)
            {
                <div class="d-flex justify-content-between align-items-center mb-1 ms-2">
                    <div>
                        <span class="@(item.Status == OrderStatus.ReadyToBeServed ? "text-success text-decoration-line-through" : "")">
                            @item.Amount× @item.Name
                        </span>
                        @if (!string.IsNullOrEmpty(item.Comment))
                        {
                            <small class="text-muted d-block">@item.Comment</small>
                        }
                    </div>
                    @if (item.Status == OrderStatus.ReadyToBeServed)
                    {
                        <button class="btn btn-sm btn-success disabled">✓</button>
                    }
                    else
                    {
                        <form asp-action="UpdateOrderItemStatus" asp-controller="@Model.ControllerName" method="post">
                            <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                            <input type="hidden" name="orderId" value="@Model.OrderID" />
                            <input type="hidden" name="status" value="@(item.Status == OrderStatus.Ordered ? (int)OrderStatus.BeingPrepared : (int)OrderStatus.ReadyToBeServed)" />
                            <button type="submit" class="btn btn-sm @(item.Status == OrderStatus.BeingPrepared ? "btn-warning" : "btn-outline-secondary")">
                                @(item.Status == OrderStatus.BeingPrepared ? "Ready" : "Prepare")
                            </button>
                        </form>
                    }
                </div>
            }
        }
    }
    else
    {
        foreach (var item in Model.OrderItems)
        {
            <div class="d-flex justify-content-between align-items-center mb-1">
                <div>
                    <span class="@(item.Status == OrderStatus.ReadyToBeServed ? "text-success text-decoration-line-through" : "")">
                        @item.Amount× @item.Name
                    </span>
                    @if (!string.IsNullOrEmpty(item.Comment))
                    {
                        <small class="text-muted d-block">@item.Comment</small>
                    }
                </div>
                @if (item.Status == OrderStatus.ReadyToBeServed)
                {
                    <button class="btn btn-sm btn-success disabled">✓</button>
                }
                else
                {
                    <form asp-action="UpdateOrderItemStatus" asp-controller="@Model.ControllerName" method="post">
                        <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                        <input type="hidden" name="status" value="@(item.Status == OrderStatus.Ordered ? (int)OrderStatus.BeingPrepared : (int)OrderStatus.ReadyToBeServed)" />
                        <button type="submit" class="btn btn-sm @(item.Status == OrderStatus.BeingPrepared ? "btn-warning" : "btn-outline-secondary")">
                            @(item.Status == OrderStatus.BeingPrepared ? "Ready" : "Prepare")
                        </button>
                    </form>
                }
            </div>
        }
    }
</div>