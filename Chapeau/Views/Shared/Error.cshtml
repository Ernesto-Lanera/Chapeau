@using Chapeau.ViewModels
@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An unexpected error occurred while processing your request.</h2>

@if (Model.ShowErrorMessage)
{
    <div class="alert alert-danger" role="alert">
        <strong>Error Details:</strong> @Model.ErrorMessage
    </div>
}

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>What happened?</h3>
<p>
    An internal system error prevented the completion of your action. Ensure that any inputs were valid and try again. If the issue persists, please consult system support.
</p>
