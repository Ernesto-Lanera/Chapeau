@model List<Chapeau.Models.Order>
@{
    ViewData["Title"] = "Betaling";
}

<div class="container payment-index-container">
    <h1 class="payment-index-header">Betalen - Alle tafels</h1>

    @if (Model != null && Model.Count > 0)
    {
        @foreach (var order in Model)
        {
            <div class="card payment-index-card mb-4">
                <div class="payment-index-card-header">
                    <h5>Tafel @order.TableNumber - Bestelling #@order.OrderId</h5>
                    <small>Gast: @order.GuestName | Datum: @order.OrderDate.ToString("g")</small>
                </div>
                <div class="card-body">
                    <h6>Bestelregels</h6>
                    @if (order.Items != null && order.Items.Count > 0)
                    {
                        <table class="table table-striped table-sm payment-index-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Item</th>
                                    <th>Aantal</th>
                                    <th>Stukprijs</th>
                                    <th>BTW-tarief</th>
                                    <th>Subtotaal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in order.Items)
                                {
                                    var subtotal = item.Price * item.AmountOrdered;
                                    var vatAmount = subtotal * item.VATRate;
                                    var totalWithVat = subtotal + vatAmount;
                                    
                                    <tr>
                                        <td class="item-name">@item.Name</td>
                                        <td>@item.AmountOrdered</td>
                                        <td class="item-price">€@item.Price.ToString("F2")</td>
                                        <td>@((item.VATRate * 100).ToString("F0"))%</td>
                                        <td>
                                            <small>€@subtotal.ToString("F2")</small><br />
                                            <small class="text-muted">+€@vatAmount.ToString("F2") BTW</small><br />
                                            <strong>€@totalWithVat.ToString("F2")</strong>
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(item.Comment))
                                    {
                                        <tr>
                                            <td colspan="5" class="item-comment">Opmerking: @item.Comment</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        <!-- VAT Summary -->
                        <div class="row mt-3">
                            <div class="col-md-8"></div>
                            <div class="col-md-4">
                                <div class="vat-summary-card">
                                    <h6>BTW verdeling:</h6>
                                    <p class="mb-1">
                                        <strong>Lage BTW (6%):</strong> 
                                        €@order.Items.Where(i => i.VATRate == 0.06m).Sum(i => i.Price * i.AmountOrdered * i.VATRate).ToString("F2")
                                    </p>
                                    <p class="mb-2">
                                        <strong>Hoge BTW (21%):</strong> 
                                        €@order.Items.Where(i => i.VATRate == 0.21m).Sum(i => i.Price * i.AmountOrdered * i.VATRate).ToString("F2")
                                    </p>
                                    <hr />
                                    <div class="total-summary">
                                        <strong>Totaal (incl. BTW): €@order.Items.Sum(i => i.Price * i.AmountOrdered * (1 + i.VATRate)).ToString("F2")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            Geen items in de order.
                        </div>
                    }

                    
                    <div class="mt-3">
                        <a href="@Url.Action("CheckoutOrder", "Payment", new { orderId = order.OrderId, tableNumber = order.TableNumber })"
                           class="btn btn-success btn-lg">
                            Afrekenen - Tafel @order.TableNumber
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info" role="alert">
            Geen actieve bestellingen op dit moment.
        </div>
    }

    <div class="mt-4">
        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Terug</a>
    </div>
</div>

@section Scripts {
    <script src="~/js/payment-index.js"></script>
}