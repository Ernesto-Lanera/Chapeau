@model List<Chapeau.Models.Order>
@{
    ViewData["Title"] = "Betaling";
    var ordersByTable = Model?.GroupBy(o => o.TableNumber).ToList();
}

<div class="container payment-index-container">
    <h1 class="payment-index-header">Betalen - Alle tafels</h1>

    @if (ordersByTable != null && ordersByTable.Count > 0)
    {
        @foreach (var tableGroup in ordersByTable)
        {
            var allItems = tableGroup.SelectMany(o => o.Items ?? new List<Chapeau.Models.OrderItem>()).ToList();
            var orderIds = tableGroup.Select(o => o.OrderId).ToList();

            <div class="card payment-index-card mb-4">
                <div class="payment-index-card-header">
                    <h5>Tafel @tableGroup.Key</h5>
                    <small>
                        @string.Join(", ", tableGroup.Select(o => $"Bestelling #{o.OrderId}")) |
                        Gast: @tableGroup.First().GuestName
                    </small>
                </div>
                <div class="card-body">
                    <h6>Bestelregels</h6>
                    @if (allItems.Count > 0)
                    {
                        <partial name="_PaymentItemsTable" model="allItems" />

                        <!-- VAT Summary -->
                        <div class="row mt-3">
                            <div class="col-md-8"></div>
                            <div class="col-md-4">
                                <div class="vat-summary-card">
                                    <h6>BTW verdeling:</h6>
                                    <p class="mb-1">
                                        <strong>Lage BTW (6%):</strong>
                                        €@allItems.Where(i => i.VATRate == 0.06m).Sum(i => i.Price * i.Amount * i.VATRate).ToString("F2")
                                    </p>
                                    <p class="mb-2">
                                        <strong>Hoge BTW (21%):</strong>
                                        €@allItems.Where(i => i.VATRate == 0.21m).Sum(i => i.Price * i.Amount * i.VATRate).ToString("F2")
                                    </p>
                                    <hr />
                                    <div class="total-summary">
                                        <strong>Totaal (incl. BTW): €@allItems.Sum(i => i.Price * i.Amount * (1 + i.VATRate)).ToString("F2")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mt-3">
                        <a href="@Url.Action("CheckoutTable", "Payment", new { tableId = tableGroup.First().TableId })"
                           class="btn btn-success btn-lg">
                            Afrekenen - Tafel @tableGroup.Key
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">Geen actieve bestellingen op dit moment.</div>
    }

    <div class="mt-4">
        <a href="@Url.Action("Index", "Table")" class="btn btn-secondary">Terug</a>
    </div>
</div>