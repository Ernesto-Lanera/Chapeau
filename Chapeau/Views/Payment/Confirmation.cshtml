@{
    ViewData["Title"] = "Betaling ontvangen";
}

<div class="container mt-5 text-center">
    <div style="width:80px; height:80px; border-radius:50%; border:3px solid green;
        display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
        <i class="bi bi-check-lg" style="font-size:2rem; color:green;"></i>
    </div>

    <h2>Betaling bevestigd!</h2>
    <p class="text-muted">€@ViewBag.Amount via @ViewBag.Method</p>
    @if (ViewBag.TipAmount is decimal tip && tip > 0)
    {
        <p class="text-muted">Tip: €@tip.ToString("F2")</p>
    }
    @if (!string.IsNullOrWhiteSpace(ViewBag.Feedback as string))
    {
        <p class="text-muted">Opmerking: @ViewBag.Feedback</p>
    }

    <hr class="w-25 mx-auto my-4" />

    <a href="@Url.Action("Index", "Payment")" class="btn btn-secondary">Terug</a>
</div>