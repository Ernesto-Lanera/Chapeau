@model Chapeau.ViewModels.PaymentOrderViewModel
@{
    ViewData["Title"] = "Payment Details";
}

<div class="container payment-container">
    <h1 class="payment-header">Order Payment Details</h1>

    @if (Model != null)
    {
        <div id="orderSection">
            <div class="card payment-card">
                <div class="payment-card-header">
                    <h5>Table @Model.TableNumber</h5>
                </div>
                <div class="payment-card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>Order ID:</strong> @Model.OrderID</p>
                        </div>
                    </div>

                    <hr />

                    <h5>Order Items</h5>
                    @if (Model.Items != null && Model.Items.Count > 0)
                    {
                        <partial name="_PaymentItemsTable" model="Model.Items" />

                        <div class="row mt-4">
                            <div class="col-md-8"></div>
                            <div class="col-md-4">
                                <div class="card vat-breakdown-card">
                                    <div class="card-body">
                                        <h6>VAT Breakdown:</h6>
                                        <div class="d-flex justify-content-between">
                                            <span>Lage BTW (6%):</span>
                                            <strong>€@Model.LowVAT.ToString("F2")</strong>
                                        </div>
                                        <div class="d-flex justify-content-between">
                                            <span>Hoge BTW (21%):</span>
                                            <strong>€@Model.HighVAT.ToString("F2")</strong>
                                        </div>
                                        <hr />
                                        <div class="total-amount">Total (incl. VAT): €@Model.Total.ToString("F2")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert payment-alert payment-alert-info">
                            No items in this order.
                        </div>
                    }

                    <div class="mt-4">
        <a href="@Url.Action("Index", "Payment")" class="btn btn-secondary">Terug</a>
                        <button type="button" class="btn btn-success btn-lg" onclick="showCheckout()">
                            Checkout
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div id="checkoutSection" style="display:none;" class="mt-4">
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-5">
                    <div class="card payment-card">
                        <div class="payment-card-body">

                            <p class="checkout-table-label">Table</p>
                            <p class="checkout-table-number">@Model.TableNumber</p>

                            <div class="checkout-total-row">
                                <span class="text-muted">Total:</span>
                                <span class="checkout-grand-total">€@Model.Total.ToString("F2")</span>
                            </div>

                            <div id="tipRow" class="checkout-tip-row" style="display:none;">
                                <span class="text-muted small">Tip:</span>
                                <span id="tipDisp" class="badge bg-success fs-6"></span>
                            </div>

                            <div class="remaining-amount" id="remainingContainer">
                                <span>Remaining:</span>
                                <span id="remainingDisplay">€@Model.Total.ToString("F2")</span>
                            </div>

                            <div class="payment-form-group">
                                <label class="form-label">Enter amount to pay:</label>
                                <input type="number" id="amountInput" class="form-control"
                                       placeholder="0.00" min="0" step="0.01" oninput="calcStatus()" />
                            </div>

                            <div class="payment-method-group">
                                <label class="form-label">Select a payment method:</label>
                                <select id="paymentMethod" class="form-select">
                                    <option value="Card">Card</option>
                                    <option value="Cash">Cash</option>
                                </select>
                            </div>

                            <div class="form-check mb-3">
                                <input class="form-check-input payment-checkbox" type="checkbox"
                                       id="splitCheck" onchange="toggleSplit()" />
                                <label class="form-check-label" for="splitCheck">
                                    Split equally
                                    <small class="text-muted">*optional</small>
                                </label>
                            </div>

                            <div id="splitSection" style="display:none;" class="split-section">
                                <label class="form-label">Number of people:</label>
                                <select id="splitCount" class="form-select" onchange="applySplit()">
                                    <option>1</option>
                                    <option>2</option>
                                    <option>3</option>
                                    <option>4</option>
                                </select>
                                <div class="per-person-amount">
                                    Per person: <strong id="perPerson">€@Model.Total.ToString("F2")</strong>
                                </div>
                                <div id="splitFeedbackFields" class="mt-3"></div>
                            </div>

                            <div class="payment-form-group">
                                <label class="form-label">Guest Feedback (optional):</label>
                                <textarea id="feedbackInput" class="form-control"
                                          placeholder="e.g. The food was wonderful!"
                                          rows="3" maxlength="255"></textarea>
                                <small class="text-muted">Max 255 characters</small>
                            </div>

                            <button type="button" class="btn payment-button w-100 mt-2" onclick="addPayment()">
                                Add payment
                            </button>

                            <div id="paymentsList" style="display:none;" class="mt-3">
                                <hr />
                                <p class="small text-muted mb-2">Payments added:</p>
                                <div id="paymentsContainer"></div>
                                <div class="d-flex justify-content-between mt-2 small">
                                    <span class="text-muted">Still to pay:</span>
                                    <strong id="stillToPay">€0,00</strong>
                                </div>
                                <button type="button" class="btn payment-button w-100 mt-3" onclick="doPay()">
                                    Pay all
                                </button>
                            </div>

                            <button type="button" class="btn btn-outline-secondary w-100 mt-2" onclick="hideCheckout()">
                                Back to order
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="confirmSection" style="display:none;" class="mt-4">
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-5 text-center">
                    <div class="card payment-card">
                        <div class="payment-card-body">

                            <div class="confirm-check-circle mx-auto mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36"
                                     fill="none" viewBox="0 0 24 24" stroke="#198754" stroke-width="2.5">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                            </div>

                            <h3 class="fw-medium mb-1">Payment received!</h3>
                            <p class="text-muted small mb-4" id="confirmSub"></p>

                            <hr />

                            <div id="confirmDetails" class="text-start small text-muted mb-4"></div>

                            <a href="@Url.Action("Index", "Payment")" class="btn payment-button w-100">
                                Return
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="paymentData"
             data-total="@Model.Total.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
             data-order-ids="@string.Join(",", Model.OrderIDs)"
             data-table-number="@Model.TableNumber"
             style="display:none;">
        </div>
    }
    else
    {
        <div class="alert payment-alert payment-alert-warning">
            No order found for this table.
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/payment.js"></script>
}
