@model Chapeau.ViewModels.StockOverviewViewModel

@{
    ViewData["Title"] = "Voorraad Beheer";
}

<div class="page-content">
    <div class="page-title-row">
        <h2 class="page-title">Voorraad Beheer</h2>
    </div>

    <form id="stockFilterForm" asp-action="Index" method="get" class="preserve-scroll-form">
        <div class="filter-row">
            <div class="filter-group">
                <label for="cardFilter">Kaart</label>
                <select name="cardId" id="cardFilter">
                    <option value="">Alle</option>
                    @foreach (var card in Model.MenuCards)
                    {
                        <option value="@card.MenuCardID" selected="@(Model.SelectedCardId == card.MenuCardID)">
                            @card.Name
                        </option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label for="categoryFilter">Categorie</label>
                <select name="categoryId" id="categoryFilter">
                    <option value="">Alle</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryID" selected="@(Model.SelectedCategoryId == category.CategoryID)">
                            @category.DisplayName
                        </option>
                    }
                </select>
            </div>
        </div>
    </form>

    <div class="stock-summary-row">
        <span class="stock-pill danger">
            Uitverkocht: <span id="soldOutCount">@Model.SoldOutCount</span> item(s)
        </span>
        <span class="stock-pill warn">
            Bijna op: <span id="almostOutCount">@Model.AlmostOutCount</span> item(s)
        </span>
    </div>

    <div class="stock-table-card">
        <table class="stock-table" id="stockTable">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Kaart</th>
                    <th>Categorie</th>
                    <th>Voorraad</th>
                    <th>Status</th>
                    <th>Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.MenuItems)
                {
                    <tr class="@item.StockRowCssClass">
                        <td>@item.Name</td>
                        <td>@item.Category.MenuCardName</td>
                        <td>@item.Category.DisplayName</td>
                        <td>
                            @if (item.CanChangeStock)
                            {
                                <input class="stock-input stock-current" type="number" min="0" value="@item.Stock" />
                            }
                            else
                            {
                                <input class="stock-input stock-current" type="number" min="0" value="@item.Stock"
                                       disabled="disabled" aria-label="Voorraad niet wijzigbaar: menu-item is inactief" />
                            }
                        </td>
                        <td>
                            <span class="stock-pill @item.StockDisplayStatusCssClass stock-status">
                                <span class="stock-status-text">@item.StockDisplayStatusText</span>
                            </span>
                        </td>
                        <td>
                            @if (item.CanChangeStock)
                            {
                                <form asp-action="Update" method="post"
                                      class="inline-stock-form stock-form preserve-scroll-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.MenuItemID" />
                                    <input type="hidden" name="newStock" class="stock-new" value="@item.Stock" />
                                    <input type="hidden" name="cardId" value="@Model.SelectedCardId" />
                                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                    <button type="submit" class="stock-action-button stock-plus stock-delta preserve-scroll"
                                            data-delta="10" title="+10">+10</button>
                                    <button type="submit" class="stock-action-button stock-minus stock-delta preserve-scroll"
                                            data-delta="-1" title="-1">-1</button>
                                </form>
                            }
                            else
                            {
                                <span class="stock-disabled-action">Niet wijzigbaar</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/stock.js" asp-append-version="true"></script>
}
