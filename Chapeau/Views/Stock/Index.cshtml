@model IEnumerable<Chapeau.Models.MenuItem>

@{
    ViewData["Title"] = "Voorraad";

    int? selectedCardId = null;
    int? selectedCategoryId = null;

    if (ViewBag.SelectedCardId != null)
    {
        selectedCardId = Convert.ToInt32(ViewBag.SelectedCardId);
    }

    if (ViewBag.SelectedCategoryId != null)
    {
        selectedCategoryId = Convert.ToInt32(ViewBag.SelectedCategoryId);
    }

    var tableCategories = ViewBag.AllCategories as IEnumerable<Chapeau.Models.Category>;
    if (tableCategories == null)
    {
        tableCategories = Enumerable.Empty<Chapeau.Models.Category>();
    }

    var filterCategories = ViewBag.FilterCategories as IEnumerable<Chapeau.Models.Category>;
    if (filterCategories == null)
    {
        filterCategories = tableCategories;
    }

    var menuCards = ViewBag.MenuCards as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    if (menuCards == null)
    {
        menuCards = Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    }

    string GetMenuCardName(int menuCardId)
    {
        return menuCardId switch
        {
            1 => "Lunch",
            2 => "Diner",
            3 => "Dranken",
            _ => "Onbekend"
        };
    }

    string GetCategoryDisplayName(Chapeau.Models.Category category)
    {
        if (category.MenuCardID == 1 || category.MenuCardID == 2)
        {
            return $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
        }

        return category.Name;
    }

    string GetStockClass(int stock)
    {
        if (stock <= 0)
        {
            return "stock-danger";
        }

        if (stock <= 5)
        {
            return "stock-warning";
        }

        return "stock-good";
    }

    string GetStockText(int stock)
    {
        if (stock <= 0)
        {
            return "Uitverkocht";
        }

        if (stock <= 5)
        {
            return "Bijna op";
        }

        return "Beschikbaar";
    }
}

<style>
    body {
        background-color: #f8fafc;
    }

    .page-content {
        padding: 28px 24px;
    }

    .page-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .filter-row {
        display: flex;
        gap: 14px;
        margin-bottom: 22px;
        align-items: end;
        flex-wrap: wrap;
    }

    .filter-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .filter-group select {
        height: 38px;
        border: 1px solid #d1d5db;
        border-radius: 7px;
        background-color: white;
        font-size: 14px;
        padding-left: 10px;
    }

        .filter-group select[name="cardId"] {
            width: 140px;
        }

        .filter-group select[name="categoryId"] {
            width: 330px;
            max-width: 100%;
            text-overflow: ellipsis;
        }

        .filter-group select:focus {
            border-color: #93c5fd;
            outline: none;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

    .stock-table-card {
        background-color: white;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
    }

    .stock-table {
        width: 100%;
        margin: 0;
        border-collapse: collapse;
    }

        .stock-table thead {
            background-color: #f9fafb;
        }

        .stock-table th {
            padding: 16px 22px;
            font-size: 14px;
            font-weight: 700;
            color: #111827;
            text-align: left;
        }

        .stock-table td {
            padding: 17px 22px;
            border-top: 1px solid #f1f5f9;
            color: #374151;
            font-size: 14px;
            vertical-align: middle;
        }

        .stock-table tbody tr:hover {
            background-color: #f9fafb;
        }

    .stock-badge {
        display: inline-block;
        padding: 4px 9px;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 600;
    }

    .stock-good {
        background-color: #dcfce7;
        color: #166534;
    }

    .stock-warning {
        background-color: #fef3c7;
        color: #92400e;
    }

    .stock-danger {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .stock-form {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0;
    }

    .stock-input {
        width: 90px;
        height: 36px;
        border: 1px solid #d1d5db;
        border-radius: 7px;
        padding: 6px 10px;
    }

    .btn-save-stock {
        height: 36px;
        background-color: #2563eb;
        color: white;
        border: none;
        border-radius: 7px;
        padding: 0 14px;
        font-weight: 600;
    }

        .btn-save-stock:hover {
            background-color: #1d4ed8;
            color: white;
        }
</style>

<div class="page-content">
    <div class="page-title-row">
        <h2 class="page-title">Voorraad Beheer</h2>
    </div>

    <form id="stockFilterForm"
          method="get"
          action="@Url.Action("Index", "Stock")"
          class="preserve-scroll-form">

        <div class="filter-row">
            <div class="filter-group">
                <label>Kaart</label>

                <select id="stockCardFilter" name="cardId">
                    <option value="">Alle</option>

                    @foreach (var card in menuCards)
                    {
                        if (selectedCardId.HasValue && selectedCardId.Value.ToString() == card.Value)
                        {
                            <option value="@card.Value" selected="selected">@card.Text</option>
                        }
                        else
                        {
                            <option value="@card.Value">@card.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <label>Categorie</label>

                <select id="stockCategoryFilter" name="categoryId">
                    <option value="">Alle</option>

                    @foreach (var category in filterCategories)
                    {
                        if (!selectedCardId.HasValue || category.MenuCardID == selectedCardId.Value)
                        {
                            if (selectedCategoryId.HasValue && selectedCategoryId.Value == category.CategoryID)
                            {
                                <option value="@category.CategoryID" selected="selected">
                                    @GetCategoryDisplayName(category)
                                </option>
                            }
                            else
                            {
                                <option value="@category.CategoryID">
                                    @GetCategoryDisplayName(category)
                                </option>
                            }
                        }
                    }
                </select>
            </div>
        </div>
    </form>

    <div class="stock-table-card">
        <table class="stock-table">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Kaart</th>
                    <th>Categorie</th>
                    <th>Voorraad</th>
                    <th>Status</th>
                    <th>Aanpassen</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    var category = tableCategories.FirstOrDefault(c => c.CategoryID == item.CategoryID);
                    string categoryName = category != null ? GetCategoryDisplayName(category) : "-";
                    string cardName = category != null ? GetMenuCardName(category.MenuCardID) : "-";
                    string stockClass = GetStockClass(item.Stock);
                    string stockText = GetStockText(item.Stock);

                    <tr>
                        <td>@item.Name</td>
                        <td>@cardName</td>
                        <td>@categoryName</td>
                        <td>@item.Stock</td>
                        <td>
                            <span class="stock-badge @stockClass">
                                @stockText
                            </span>
                        </td>
                        <td>
                            <form method="post"
                                  action="@Url.Action("ChangeStock", "Stock")"
                                  class="stock-form preserve-scroll-form">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@item.MenuItemID" />
                                <input type="hidden" name="cardId" value="@selectedCardId" />
                                <input type="hidden" name="categoryId" value="@selectedCategoryId" />

                                <input type="number"
                                       name="stock"
                                       value="@item.Stock"
                                       min="0"
                                       class="stock-input" />

                                <button type="submit"
                                        class="btn-save-stock preserve-scroll">
                                    Opslaan
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const filterForm = document.getElementById("stockFilterForm");
        const cardFilter = document.getElementById("stockCardFilter");
        const categoryFilter = document.getElementById("stockCategoryFilter");

        if (!filterForm || !cardFilter || !categoryFilter) {
            return;
        }

        cardFilter.addEventListener("change", function () {
            categoryFilter.value = "";
            filterForm.submit();
        });

        categoryFilter.addEventListener("change", function () {
            filterForm.submit();
        });
    });
</script>