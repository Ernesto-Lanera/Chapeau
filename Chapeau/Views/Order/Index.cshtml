@model List<Someren.Models.Order>
@{
    ViewData["Title"] = "Orders List";
}

@if (TempData["AlertMessage"] != null)
{
    <div class="alert @TempData["AlertType"] alert-dismissible fade show" role="alert">
        <strong>Notification:</strong> @TempData["AlertMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="display-3">Orders</h1>
    <a href="/Order/Create" class="btn btn-primary">
        Place New Order <i class="bi bi-plus-circle-fill"></i>
    </a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table">
        <tr>
            <th>Date</th>
            <th>Student</th>
            <th>Total Unique Drinks</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderDate.ToString("g")</td>
                <td>@await Component.InvokeAsync("StudentField", new { selectedId = order.TableId })</td>
                <td>@(order.OrderParts?.Count ?? 0)</td>
                <td>
                    <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#orderDetails-@order.OrderId">
                        Manage Order <i class="bi bi-chevron-down"></i>
                    </button>
                </td>
            </tr>

            <tr class="collapse" id="orderDetails-@order.OrderId">
                <td colspan="5" class="bg-light p-4 text-start border-bottom border-primary border-3">
                    
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0 text-primary">Drinks for Order #@order.OrderId</h5>
                        
                        <div>
                            <a class="btn btn-sm btn-success me-3" href="/OrderPart/Create?orderId=@order.OrderId">
                                <i class="bi bi-plus-circle"></i> Add Drink to this Order
                            </a>
                            <a class="btn btn-sm btn-warning me-2" asp-action="Edit" asp-route-id="@order.OrderId">
                                <i class="bi bi-pencil-fill"></i> Edit Order
                            </a>
                            
                            <a class="btn btn-sm btn-danger me-2" asp-action="Delete" asp-route-id="@order.OrderId">
                                Delete Order
                            </a>
                        </div>
                    </div>

                    @if (order.OrderParts != null && order.OrderParts.Any())
                    {
                        <table class="table table-sm table-bordered bg-white shadow-sm mb-0">
                            <thead class="table-secondary text-center">
                                <tr>
                                    <th>Drink</th>
                                    <th>Quantity</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody class="text-center">
                                @foreach (var part in order.OrderParts)
                                {
                                    <tr>
                                        <td>@await Component.InvokeAsync("DrinkField", new { selectedId = part.MenuItemId })</td>
                                        <td>@part.Amount</td>
                                        <td>
                                            <div class="d-flex justify-content-center">
                                                <a class="btn btn-sm btn-warning me-2" asp-controller="OrderPart" asp-action="Edit" asp-route-id="@part.OrderPartId">
                                                    <i class="bi bi-pencil-fill"></i> Edit
                                                </a>
                        
                                                <a class="btn btn-sm btn-danger" asp-controller="OrderPart" asp-action="Delete" asp-route-id="@part.OrderPartId">
                                                    <i class="bi bi-trash3-fill"></i> Delete
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-secondary mb-0 py-2">
                            No drinks have been added to this order yet.
                        </div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>