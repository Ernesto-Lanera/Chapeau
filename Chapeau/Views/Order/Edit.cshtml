@model Chapeau.Models.Order
@{
    ViewData["Title"] = "Create Order";
}

<h1 class="display-4">Delete Order</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form action="/Order/Edit" method="post">

            <input hidden type="number" name="OrderId" value="@Model?.OrderId" />
            <div class="form-group py-2">
                <label for="OrderDate">Order Date:</label>
                <input type="datetime-local" name="OrderDate" id="OrderDate"
                       class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"/>
            </div>

            <div class="form-group py-2">
                <label>Select Student (Customer):</label>
                @await Component.InvokeAsync("StudentDropdown", new { selectedId = Model?.TableId })
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-warning btn-lg">Edit Order</button>
                <a href="/Order/Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>