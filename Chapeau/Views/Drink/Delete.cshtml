@model Someren.Models.Drink
@{
    ViewData["Title"] = "Delete Drink";
}

<h1 class="display-4 text-danger">Remove Drink</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form action="/Drink/Delete" method="post">
            <input hidden type="number" name="DrinkId" value="@Model?.DrinkId" />

            <div class="form-group py-2">
                <label for="DrinkName">Drink Name:</label>
                <input type="text" id="DrinkName" class="form-control" disabled value="@Model?.DrinkName" />
            </div>

            <div class="form-group py-2">
                <label for="Price">Price:</label>
                <input type="text" id="Price" class="form-control" disabled value="@Model?.Price.ToString("C")" />
            </div>

            <div class="form-group py-2">
                <label for="Stock">Current Stock:</label>
                <input type="number" id="Stock" class="form-control" disabled value="@Model?.Stock" />
            </div>

            <div class="form-group py-2">
                <label for="Alcoholic">Type:</label>
                <input type="text" id="Alcoholic" class="form-control" disabled value="@(Model != null && Model.Alcoholic ? "Alcoholic" : "Non-Alcoholic")" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-danger">Confirm Delete <i class="bi bi-trash3-fill"></i></button>
                <a href="/Drink/Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>