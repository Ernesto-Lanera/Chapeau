@{
    ViewBag.Title = "Financial Overview";
}

<h2>Financial Overview</h2>

<p class="text-muted">
    <em>This is a placeholder for the Financial Overview. The data for total sales, costs, and tips relies on the Order functionality which will be implemented in Sprint 3.</em>
</p>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-primary">
            <div class="card-header">Total Sales</div>
            <div class="card-body">
                <h5 class="card-title">€ 0.00</h5>
                <p class="card-text">Drinks: € 0.00<br/>Lunch: € 0.00<br/>Dinner: € 0.00</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card text-white bg-success">
            <div class="card-header">Total Income</div>
            <div class="card-body">
                <h5 class="card-title">€ 0.00</h5>
                <p class="card-text">Drinks: € 0.00<br/>Lunch: € 0.00<br/>Dinner: € 0.00</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card text-dark bg-warning">
            <div class="card-header">Total Tips</div>
            <div class="card-body">
                <h5 class="card-title">€ 0.00</h5>
                <p class="card-text">From all orders today</p>
            </div>
        </div>
    </div>
</div>
