@model Chapeau.ViewModels.FinancialOverviewViewModel
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Financieel Overzicht";

    CultureInfo nlCulture = CultureInfo.GetCultureInfo("nl-NL");
    string Money(decimal amount) => $"€ {amount.ToString("0.00", CultureInfo.InvariantCulture)}";
    decimal Average(decimal total, int quantity) => quantity > 0 ? total / quantity : 0m;

    var trendLabels = Model.RevenueTrend
        .Select(item => item.MonthStart.ToString("MMM", nlCulture))
        .ToList();
    var drinksTrend = Model.RevenueTrend.Select(item => item.DrinksIncome).ToList();
    var lunchTrend = Model.RevenueTrend.Select(item => item.LunchIncome).ToList();
    var dinnerTrend = Model.RevenueTrend.Select(item => item.DinnerIncome).ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/finance.css" asp-append-version="true" />
}

<div class="finance-dashboard">
    <h1 class="finance-page-title">Financieel Overzicht</h1>

    <section class="finance-panel finance-period-panel" aria-label="Periode selectie">
        <h2 class="finance-panel-title">Periode Selectie</h2>

        <div class="finance-period-buttons" role="group" aria-label="Kies een periode">
            <a asp-controller="Finance"
               asp-action="Index"
               asp-route-period="month"
               class="finance-period-button @(Model.SelectedPeriod == "month" ? "is-selected" : "")">
                Deze Maand
            </a>
            <a asp-controller="Finance"
               asp-action="Index"
               asp-route-period="quarter"
               class="finance-period-button @(Model.SelectedPeriod == "quarter" ? "is-selected" : "")">
                Dit Kwartaal
            </a>
            <a asp-controller="Finance"
               asp-action="Index"
               asp-route-period="year"
               class="finance-period-button @(Model.SelectedPeriod == "year" ? "is-selected" : "")">
                Dit Jaar
            </a>
            <button id="selectCustomPeriod"
                    type="button"
                    aria-controls="customPeriodForm"
                    aria-expanded="@(Model.SelectedPeriod == "custom" ? "true" : "false")"
                    class="finance-period-button finance-custom-period-button @(Model.SelectedPeriod == "custom" ? "is-selected" : "")">
                <i class="bi bi-calendar3" aria-hidden="true"></i>
                Aangepaste Periode
            </button>
        </div>

        <form asp-controller="Finance"
              asp-action="Index"
              method="get"
              id="customPeriodForm"
              class="finance-custom-period-form"
              hidden="@(Model.SelectedPeriod == "custom" ? null : "hidden")">
            <input type="hidden" name="period" value="custom" />

            <div class="finance-field">
                <label for="startDate">Startdatum</label>
                <input id="startDate"
                       name="startDate"
                       type="date"
                       value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")"
                       required />
            </div>

            <div class="finance-field">
                <label for="endDate">Einddatum</label>
                <input id="endDate"
                       name="endDate"
                       type="date"
                       value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")"
                       required />
            </div>

            <button type="submit" class="finance-submit-button">Toepassen</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.FilterError))
        {
            <p class="finance-filter-error" role="alert">
                <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                @Model.FilterError
            </p>
        }
    </section>

    <section class="finance-kpi-grid" aria-label="Omzettotalen">
        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Omzet Dranken</p>
            <p class="finance-kpi-value is-drinks">@Money(Model.DrinksIncome)</p>
            <p class="finance-kpi-support">@Model.DrinksSalesCount bestellingen</p>
        </article>

        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Omzet Lunch</p>
            <p class="finance-kpi-value is-lunch">@Money(Model.LunchIncome)</p>
            <p class="finance-kpi-support">@Model.LunchSalesCount bestellingen</p>
        </article>

        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Omzet Diner</p>
            <p class="finance-kpi-value is-dinner">@Money(Model.DinnerIncome)</p>
            <p class="finance-kpi-support">@Model.DinnerSalesCount bestellingen</p>
        </article>

        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Fooien</p>
            <p class="finance-kpi-value is-tip">@Money(Model.TotalTips)</p>
            <p class="finance-kpi-support">van @Model.TotalSalesCount bestellingen</p>
        </article>
    </section>

    <section class="finance-panel finance-table-panel" aria-label="Omzet per categorie">
        <h2 class="finance-panel-title">Omzet per Categorie</h2>

        <div class="finance-table-wrapper">
            <table class="finance-category-table">
                <thead>
                    <tr>
                        <th>Categorie</th>
                        <th>Aantal Verkopen</th>
                        <th>Totaal Inkomen</th>
                        <th>Gemiddelde per Verkoop</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Dranken</th>
                        <td>@Model.DrinksSalesCount</td>
                        <td>@Money(Model.DrinksIncome)</td>
                        <td>@Money(Average(Model.DrinksIncome, Model.DrinksSalesCount))</td>
                    </tr>
                    <tr>
                        <th scope="row">Lunch</th>
                        <td>@Model.LunchSalesCount</td>
                        <td>@Money(Model.LunchIncome)</td>
                        <td>@Money(Average(Model.LunchIncome, Model.LunchSalesCount))</td>
                    </tr>
                    <tr>
                        <th scope="row">Diner</th>
                        <td>@Model.DinnerSalesCount</td>
                        <td>@Money(Model.DinnerIncome)</td>
                        <td>@Money(Average(Model.DinnerIncome, Model.DinnerSalesCount))</td>
                    </tr>
                    <tr class="finance-total-row">
                        <th scope="row">TOTAAL</th>
                        <td>@Model.TotalSalesCount</td>
                        <td>@Money(Model.TotalIncomeBeforeTips)</td>
                        <td>@Money(Average(Model.TotalIncomeBeforeTips, Model.TotalSalesCount))</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <section class="finance-panel finance-chart-panel" aria-label="Omzet trend">
        <h2 class="finance-panel-title">Omzet Trend</h2>
        <div class="finance-chart-container">
            <canvas id="revenueTrendChart" aria-label="Grafiek met de maandelijkse omzet van dranken, lunch en diner"></canvas>
        </div>

        <script id="revenueTrendData" type="application/json">
            @Html.Raw(JsonSerializer.Serialize(new
            {
                labels = trendLabels,
                drinks = drinksTrend,
                lunch = lunchTrend,
                dinner = dinnerTrend
            }))
        </script>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
    <script src="~/js/finance.js" asp-append-version="true"></script>
}
