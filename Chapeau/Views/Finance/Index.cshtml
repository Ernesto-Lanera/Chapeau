@model Chapeau.ViewModels.FinancialViewModel
@using Chapeau.Emums
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Financieel Overzicht";
    CultureInfo culture = CultureInfo.GetCultureInfo("nl-NL");
    string Money(decimal amount) => amount.ToString("C2", culture);

    var trendLabels = Model.RevenueTrend.Select(item => item.MonthStart.ToString("MMM yyyy", culture)).ToList();
    var drinksTrend = Model.RevenueTrend.Select(item => item.DrinksIncome).ToList();
    var lunchTrend = Model.RevenueTrend.Select(item => item.LunchIncome).ToList();
    var dinnerTrend = Model.RevenueTrend.Select(item => item.DinnerIncome).ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/finance.css" asp-append-version="true" />
}

<div class="finance-dashboard">
    <h1 class="finance-page-title">Financieel Overzicht</h1>

    <section class="finance-panel finance-period-panel" aria-label="Periode selectie">
        <h2 class="finance-panel-title">Periode Selectie</h2>

        <div class="finance-period-buttons" role="group" aria-label="Kies een periode">
            <a asp-action="Index" asp-route-period="month"
               class="finance-period-button @(Model.SelectedPeriod == FinancialPeriod.Month ? "is-selected" : "")">
                Deze Maand
            </a>
            <a asp-action="Index" asp-route-period="quarter"
               class="finance-period-button @(Model.SelectedPeriod == FinancialPeriod.Quarter ? "is-selected" : "")">
                Dit Kwartaal
            </a>
            <a asp-action="Index" asp-route-period="year"
               class="finance-period-button @(Model.SelectedPeriod == FinancialPeriod.Year ? "is-selected" : "")">
                Dit Jaar
            </a>
            <button id="selectCustomPeriod" type="button" aria-controls="customPeriodForm"
                    aria-expanded="@(Model.SelectedPeriod == FinancialPeriod.Custom ? "true" : "false")"
                    class="finance-period-button finance-custom-period-button @(Model.SelectedPeriod == FinancialPeriod.Custom ? "is-selected" : "")">
                <i class="bi bi-calendar3" aria-hidden="true"></i>
                Aangepaste Periode
            </button>
        </div>

        <form asp-action="Index" method="get" id="customPeriodForm"
              class="finance-custom-period-form"
              hidden="@(Model.SelectedPeriod == FinancialPeriod.Custom ? null : "hidden")">
            <input type="hidden" name="period" value="custom" />
            <div class="finance-field">
                <label for="startDate">Startdatum</label>
                <input id="startDate" name="startDate" type="date"
                       value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="finance-field">
                <label for="endDate">Einddatum</label>
                <input id="endDate" name="endDate" type="date"
                       value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" required />
            </div>
            <button type="submit" class="finance-submit-button">Toepassen</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.FilterError))
        {
            <p class="finance-filter-error" role="alert">
                <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                @Model.FilterError
            </p>
        }
        <p class="text-muted mb-0">Getoonde periode: @Model.PeriodDisplay</p>
    </section>

    <section class="finance-kpi-grid" aria-label="Omzettotalen">
        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Omzet Dranken</p>
            <p class="finance-kpi-value is-drinks">@Money(Model.DrinksIncome)</p>
            <p class="finance-kpi-support">alleen betaalde orders</p>
        </article>
        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Omzet Lunch</p>
            <p class="finance-kpi-value is-lunch">@Money(Model.LunchIncome)</p>
            <p class="finance-kpi-support">alleen betaalde orders</p>
        </article>
        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Omzet Diner</p>
            <p class="finance-kpi-value is-dinner">@Money(Model.DinnerIncome)</p>
            <p class="finance-kpi-support">alleen betaalde orders</p>
        </article>
        <article class="finance-kpi-card">
            <p class="finance-kpi-label">Totaal Fooien</p>
            <p class="finance-kpi-value is-tip">@Money(Model.TotalTips)</p>
            <p class="finance-kpi-support">uit de Payment tabel</p>
        </article>
    </section>

    <section class="finance-panel finance-table-panel" aria-label="Omzet per menukaart">
        <h2 class="finance-panel-title">Verkopen en inkomsten per menukaart</h2>
        <p class="text-muted">
            Finance begint bij de Payment tabel. Alleen orders die betaald zijn tellen mee in dit overzicht.
        </p>
        <div class="finance-table-wrapper">
            <table class="finance-category-table">
                <thead>
                    <tr>
                        <th>Menukaart</th>
                        <th>Aantal verkopen</th>
                        <th>Totaal inkomen incl. BTW</th>
                        <th>Gemiddelde per item</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Dranken</th>
                        <td>@Model.DrinksSalesCount</td>
                        <td>@Money(Model.DrinksIncome)</td>
                        <td>@Money(Model.DrinksAverageIncome)</td>
                    </tr>
                    <tr>
                        <th scope="row">Lunch</th>
                        <td>@Model.LunchSalesCount</td>
                        <td>@Money(Model.LunchIncome)</td>
                        <td>@Money(Model.LunchAverageIncome)</td>
                    </tr>
                    <tr>
                        <th scope="row">Diner</th>
                        <td>@Model.DinnerSalesCount</td>
                        <td>@Money(Model.DinnerIncome)</td>
                        <td>@Money(Model.DinnerAverageIncome)</td>
                    </tr>
                    <tr class="finance-total-row">
                        <th scope="row">Totaal</th>
                        <td>@Model.TotalSalesCount</td>
                        <td>@Money(Model.TotalIncomeBeforeTips)</td>
                        <td>@Money(Model.TotalAverageIncome)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <section class="finance-panel finance-chart-panel" aria-label="Omzettrend">
        <h2 class="finance-panel-title">Omzettrend</h2>
        <p class="text-muted">
            De grafiek gebruikt dezelfde betaalde orders als de totalen hierboven.
        </p>
        <div class="finance-chart-container">
            <canvas id="revenueTrendChart" aria-label="Maandelijkse omzet per menukaart"></canvas>
        </div>
        <script id="revenueTrendData" type="application/json">
            @Html.Raw(JsonSerializer.Serialize(new
            {
                labels = trendLabels,
                drinks = drinksTrend,
                lunch = lunchTrend,
                dinner = dinnerTrend
            }))
        </script>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
    <script src="~/js/finance.js" asp-append-version="true"></script>
}
