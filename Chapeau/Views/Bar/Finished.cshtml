@model List<Chapeau.ViewModels.OrderViewModel>

@section Styles {
    <link rel="stylesheet" href="~/css/station.css" asp-append-version="true" />
    <style>
        body {
            background: #0e0f11 !important;
        }

        header {
            background: #16181c !important;
            border-bottom: 1px solid #25272c !important;
        }

            header .navbar {
                background: #16181c !important;
            }

                header .navbar * {
                    color: #ffffff !important;
                }

        /* Running Orders / Finished Orders / Refresh buttons */
        .station-nav a.btn,
        .d-flex > a.btn-outline-secondary {
            background: #16181c !important;
            border-color: #25272c !important;
            color: #ffffff !important;
        }

            .station-nav a.btn:hover,
            .d-flex > a.btn-outline-secondary:hover {
                background: #25272c !important;
            }

        .station-nav a.btn-primary {
            background: #16181c !important;
            border-color: #25272c !important;
            color: #ffffff !important;
            font-weight: 600;
        }
    </style>
}

@{
    ViewData["Title"] = "Bar - Finished";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Running Orders</a>
        <a asp-action="Finished" class="btn btn-primary">Finished Orders</a>
    </div>
    <a asp-action="Finished" class="btn btn-outline-secondary">Refresh ↻</a>
</div>

@if (Model == null || !Model.Any())
{
    <p>No finished orders today.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Table</th>
                <th>Order time</th>
                <th>Items</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.TableNumber</td>
                    <td>@order.OrderDate.ToString("HH:mm")</td>
                    <td>
                        @foreach (var item in order.OrderItems)
                        {
                            <span class="badge bg-secondary me-1">@item.Amount x @item.Name</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}