@model List<Chapeau.ViewModels.OrderViewModel>

@section Styles {
    <link rel="stylesheet" href="~/css/station.css" asp-append-version="true" />
   
}

@{
    ViewData["Title"] = "Bar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex gap-2 station-nav">
        <a asp-action="Index" class="btn btn-primary">Running Orders</a>
        <a asp-action="Finished" class="btn btn-outline-secondary">Finished Orders</a>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Refresh ↻</a>
</div>

@if (Model == null || !Model.Any())
{
    <p>No running orders.</p>
}
else
{
    <div class="order-list">
        @foreach (var order in Model)
        {
            @await Html.PartialAsync("_OrderView", order)
        }
    </div>
}