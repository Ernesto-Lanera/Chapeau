@model Someren.Models.OrderPart
@{
    ViewData["Title"] = "Edit Order Part";
}

<h1 class="display-4">Edit Drink for Order #@Model?.OrderId</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form action="/OrderPart/Edit" method="post">
            <input type="hidden" name="OrderPartId" value="@Model?.OrderPartId" />
            
            <input type="hidden" name="OrderId" value="@Model?.OrderId" />

            <div class="form-group py-2">
                <label for="MenuItemId" class="form-label">Select Drink:</label>
                @await Component.InvokeAsync("DrinkDropdown", new { selectedId = Model?.MenuItemId })
            </div>

            <div class="form-group py-2">
                <label for="Amount" class="form-label">Amount (Quantity):</label>
                <input type="number" name="Amount" id="Amount" class="form-control" required value="@Model?.Amount" min="1" />
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Changes <i class="bi bi-check-circle"></i></button>
                <a href="/Order/Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>