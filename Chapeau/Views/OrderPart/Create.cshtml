@model Chapeau.Models.OrderItem
@{
    ViewData["Title"] = "Add Drink to Order";
}

<h1 class="display-4">Add Drink to Order #@ViewBag.OrderId</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form action="/OrderPart/Create" method="post">
            <input type="hidden" name="OrderId" value="@ViewBag.OrderId" />

            <div class="form-group py-2">
                <label for="MenuItemId" class="form-label">Select Drink:</label>
                @await Component.InvokeAsync("DrinkDropdown")
            </div>

            <div class="form-group py-2">
                <label for="Amount" class="form-label">Amount (Quantity):</label>
                @await Component.InvokeAsync("StockAmountInput", new
                {
                    MenuItemId = 0,
                    currentAmount = 1
                })
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Add to Order <i class="bi bi-plus-circle"></i></button>
                <a href="/Order/Index" class="btn btn-secondary ms-2">Back to Orders</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById("MenuItemId").addEventListener("change", function () {
        var amountInput = document.getElementById("Amount");
        var stockLabel = document.getElementById("stockLabel");
        
        var selectedOption = this.options[this.selectedIndex];
        var maxStock = selectedOption.getAttribute("data-stock");

        if (this.value) {
            amountInput.disabled = false;
            amountInput.max = maxStock;
            stockLabel.innerText = "Maximum available in stock: " + maxStock;
        } else {
            amountInput.disabled = true;
            stockLabel.innerText = "Please select a drink first.";
        }
    });
</script>