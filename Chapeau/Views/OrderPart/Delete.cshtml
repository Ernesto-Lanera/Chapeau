@model Someren.Models.OrderItem
@{
    ViewData["Title"] = "Remove Drink";
}

<h1 class="display-4 text-danger">Remove Drink from Order #@Model?.OrderId</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form action="/OrderPart/Delete" method="post">
            <input type="hidden" name="OrderPartId" value="@Model?.OrderPartId" />
            
            <div class="form-group py-2">
                <label for="MenuItemId" class="form-label">Select Drink:</label>
                @await Component.InvokeAsync("DrinkDropdown", new { selectedId = Model?.MenuItemId })
            </div>

            <div class="form-group py-2">
                <label for="Amount" class="form-label">Amount (Quantity):</label>
                @await Component.InvokeAsync("StockAmountInput", new
                {
                    MenuItemId = 0,
                    currentAmount = Model!.Amount
                })
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-danger">Confirm Removal <i class="bi bi-trash3-fill"></i></button>
                <a href="/Order/Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>