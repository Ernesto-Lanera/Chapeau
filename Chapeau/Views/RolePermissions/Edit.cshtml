@model Chapeau.ViewModels.RolePermissionsEditViewModel

@{
    ViewData["Title"] = "Permissies Bewerken";
}

<div class="page-content">
    <div class="page-title-row">
        <h2 class="page-title">Permissies voor @Model.RoleName</h2>

        <a href="@Url.Action("Index", "RolePermissions")"
           class="btn-close-form">
            Terug
        </a>
    </div>

    <div class="form-card">
        <form method="post"
              action="@Url.Action("Edit", "RolePermissions", new { id = Model.RoleID })">

            <div class="permission-checklist">
                @foreach (string permission in Model.AllPermissions)
                {
                    bool isChecked = Model.CurrentPermissions.Contains(permission, StringComparer.OrdinalIgnoreCase);

                    <div class="form-check mb-2">
                        <input type="checkbox"
                               class="form-check-input"
                               name="selectedPermissions"
                               value="@permission"
                               id="perm_@permission"
                               @(isChecked ? "checked=\"checked\"" : "") />
                        <label class="form-check-label" for="perm_@permission">
                            @permission
                        </label>
                    </div>
                }
            </div>

            <div class="form-actions mt-3">
                <button type="submit" class="btn btn-primary">
                    Opslaan
                </button>

                <a href="@Url.Action("Index", "RolePermissions")"
                   class="btn btn-secondary">
                    Annuleren
                </a>
            </div>
        </form>
    </div>
</div>
