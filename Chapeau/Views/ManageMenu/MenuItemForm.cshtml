@model Chapeau.Models.MenuItem

@{
    bool isEdit = ViewBag.IsEdit != null && (bool)ViewBag.IsEdit;

    var categories = ViewBag.Categories as IEnumerable<Chapeau.Models.Category> 
        ?? Enumerable.Empty<Chapeau.Models.Category>();
    var menuCards = ViewBag.MenuCards as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> 
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // Bepaal geselecteerde kaart
    int selectedMenuCardId = 0;
    if (ViewBag.SelectedMenuCardId != null)
    {
        selectedMenuCardId = Convert.ToInt32(ViewBag.SelectedMenuCardId);
    }

    if (selectedMenuCardId <= 0)
    {
        if (isEdit)
        {
            var currentCategory = categories.FirstOrDefault(c => c.CategoryID == Model.CategoryID);
            selectedMenuCardId = currentCategory?.MenuCardID ?? 1;
        }
        else
        {
            if (int.TryParse(menuCards.FirstOrDefault()?.Value, out int parsedId))
                selectedMenuCardId = parsedId;
            else
                selectedMenuCardId = 1;
        }
    }

    string formAction = isEdit ? "Edit" : "Create";
    string buttonText = isEdit ? "Bijwerken" : "Toevoegen";
    string searchValue = ViewBag.Search as string ?? "";

    // Helpers
    string GetMenuCardName(int id) => id switch
    {
        1 => "Lunch",
        2 => "Diner",
        3 => "Dranken",
        _ => "Onbekend"
    };

    string GetCategoryDisplayName(Chapeau.Models.Category category) =>
        $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
}

<form id="menuItemEditCreateForm"
      method="post"
      action="@Url.Action(formAction, "ManageMenu")"
      enctype="multipart/form-data"
      class="preserve-scroll-form">

    @Html.AntiForgeryToken()

    <input type="hidden" name="search" value="@searchValue" />

    @if (isEdit)
    {
        <input type="hidden" name="MenuItemID" value="@Model.MenuItemID" />
        <input type="hidden" name="MenuCardID" value="@selectedMenuCardId" />
    }

    <div class="form-group mb-3">
        <label class="form-label">Kaart</label>

        @if (isEdit)
        {
            <select id="menuCardSelect" class="form-select" disabled="disabled">
                @foreach (var card in menuCards)
                {
                    if (card.Value == selectedMenuCardId.ToString())
                    {
                        <option value="@card.Value" selected="selected">@card.Text</option>
                    }
                    else
                    {
                        <option value="@card.Value">@card.Text</option>
                    }
                }
            </select>

            <small class="text-muted">
                De kaart kan niet direct worden gewijzigd. Kies alleen een categorie binnen dezelfde kaart.
            </small>
        }
        else
        {
            <select id="menuCardSelect" name="MenuCardID" class="form-select" required="required">
                <option value="">Selecteer kaart</option>

                @foreach (var card in menuCards)
                {
                    if (card.Value == selectedMenuCardId.ToString())
                    {
                        <option value="@card.Value" selected="selected">@card.Text</option>
                    }
                    else
                    {
                        <option value="@card.Value">@card.Text</option>
                    }
                }
            </select>
        }
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Naam</label>

        <input type="text"
               name="Name"
               value="@Model.Name"
               class="form-control"
               placeholder="Naam"
               maxlength="100"
               required="required" />

        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Prijs</label>

        @if (Model.RetailPrice > 0)
        {
            <input type="text"
                   name="RetailPrice"
                   value="@Model.RetailPrice.ToString("F2", new System.Globalization.CultureInfo("nl-NL"))"
                   class="form-control"
                   placeholder="Prijs, bijvoorbeeld 12,50"
                   required="required"
                   pattern="[0-9,.]+" />
        }
        else
        {
            <input type="text"
                   name="RetailPrice"
                   value=""
                   class="form-control"
                   placeholder="Prijs, bijvoorbeeld 12,50"
                   required="required"
                   pattern="[0-9,.]+" />
        }

        @Html.ValidationMessageFor(m => m.RetailPrice, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Voorraad</label>

        <input type="number"
               name="Stock"
               value="@Model.Stock"
               class="form-control"
               placeholder="Voorraad"
               min="0"
               required="required" />

        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label for="categorySelect" class="form-label">Categorie</label>

        <select id="categorySelect" name="CategoryID" class="form-select" required="required">
            <option value="">Selecteer categorie</option>

            @foreach (var category in categories)
            {
                if (Model.CategoryID == category.CategoryID)
                {
                    <option value="@category.CategoryID"
                            data-cardid="@category.MenuCardID"
                            selected="selected">
                        @GetCategoryDisplayName(category)
                    </option>
                }
                else
                {
                    <option value="@category.CategoryID"
                            data-cardid="@category.MenuCardID">
                        @GetCategoryDisplayName(category)
                    </option>
                }
            }
        </select>

        @Html.ValidationMessageFor(m => m.CategoryID, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label for="imageUpload" class="form-label">Afbeelding optioneel</label>

        <input type="file"
               id="imageUpload"
               name="imageFile"
               accept="image/*"
               class="form-control" />

        @if (isEdit && !string.IsNullOrWhiteSpace(Model.ImagePath))
        {
            <div class="mt-2">
                <img src="@Model.ImagePath"
                     alt="@Model.Name"
                     style="max-width: 150px; max-height: 150px; border-radius: 6px;" />

                <div class="small text-muted mt-2">Huidige afbeelding</div>
            </div>
        }

        <small class="form-text text-muted">
            JPG, PNG of WebP. Maximaal 10MB.
        </small>
    </div>

    @if (!isEdit)
    {
        <input type="hidden" name="IsActive" value="true" />
    }

    <div class="form-actions">
        <button type="submit" class="btn btn-primary preserve-scroll">
            @buttonText
        </button>

        <a href="@Url.Action("Index", "ManageMenu", new { search = searchValue })"
               class="btn btn-secondary preserve-scroll">
            Annuleren
        </a>
    </div>
</form>