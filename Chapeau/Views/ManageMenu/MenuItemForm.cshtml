@model Chapeau.Models.MenuItem

@{
    bool isEdit = false;

    if (ViewBag.IsEdit != null)
    {
        isEdit = (bool)ViewBag.IsEdit;
    }

    var categories = ViewBag.Categories as IEnumerable<Chapeau.Models.Category>;

    if (categories == null)
    {
        categories = Enumerable.Empty<Chapeau.Models.Category>();
    }

    var menuCards = ViewBag.MenuCards as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;

    if (menuCards == null)
    {
        menuCards = Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    }

    int selectedMenuCardId = 0;

    if (ViewBag.SelectedMenuCardId != null)
    {
        selectedMenuCardId = Convert.ToInt32(ViewBag.SelectedMenuCardId);
    }

    if (selectedMenuCardId <= 0)
    {
        var firstCard = menuCards.FirstOrDefault();

        if (firstCard != null && int.TryParse(firstCard.Value, out int parsedCardId))
        {
            selectedMenuCardId = parsedCardId;
        }
        else
        {
            selectedMenuCardId = 1;
        }
    }

    if (isEdit)
    {
        var currentCategory = categories.FirstOrDefault(c => c.CategoryID == Model.CategoryID);

        if (currentCategory != null)
        {
            selectedMenuCardId = currentCategory.MenuCardID;
        }
    }

    string formAction = isEdit ? "Edit" : "Create";
    string buttonText = isEdit ? "Bijwerken" : "Toevoegen";
    string searchValue = ViewBag.Search as string ?? "";

    string GetMenuCardName(int menuCardId)
    {
        return menuCardId switch
        {
            1 => "Lunch",
            2 => "Diner",
            3 => "Dranken",
            _ => "Onbekend"
        };
    }

    string GetCategoryDisplayName(Chapeau.Models.Category category)
    {
        return $"{category.Name} ({GetMenuCardName(category.MenuCardID)})";
    }
}

<form id="menuItemEditCreateForm"
      method="post"
      action="@Url.Action(formAction, "ManageMenu")"
      enctype="multipart/form-data"
      class="preserve-scroll-form">

    @Html.AntiForgeryToken()

    <input type="hidden" name="search" value="@searchValue" />

    @if (isEdit)
    {
        <input type="hidden" name="MenuItemID" value="@Model.MenuItemID" />
        <input type="hidden" name="MenuCardID" value="@selectedMenuCardId" />
    }

    <div class="form-group mb-3">
        <label class="form-label">Kaart</label>

        @if (isEdit)
        {
            <select id="menuCardSelect" class="form-select" disabled="disabled">
                @foreach (var card in menuCards)
                {
                    if (card.Value == selectedMenuCardId.ToString())
                    {
                        <option value="@card.Value" selected="selected">@card.Text</option>
                    }
                    else
                    {
                        <option value="@card.Value">@card.Text</option>
                    }
                }
            </select>

            <small class="text-muted">
                De kaart kan niet direct worden gewijzigd. Kies alleen een categorie binnen dezelfde kaart.
            </small>
        }
        else
        {
            <select id="menuCardSelect" name="MenuCardID" class="form-select" required="required">
                <option value="">Selecteer kaart</option>

                @foreach (var card in menuCards)
                {
                    if (card.Value == selectedMenuCardId.ToString())
                    {
                        <option value="@card.Value" selected="selected">@card.Text</option>
                    }
                    else
                    {
                        <option value="@card.Value">@card.Text</option>
                    }
                }
            </select>
        }
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Naam</label>

        <input type="text"
               name="Name"
               value="@Model.Name"
               class="form-control"
               placeholder="Naam"
               maxlength="100"
               required="required" />

        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Prijs</label>

        @if (Model.RetailPrice > 0)
        {
            <input type="text"
                   name="RetailPrice"
                   value="@Model.RetailPrice.ToString("F2", new System.Globalization.CultureInfo("nl-NL"))"
                   class="form-control"
                   placeholder="Prijs, bijvoorbeeld 12,50"
                   required="required"
                   pattern="[0-9,.]+" />
        }
        else
        {
            <input type="text"
                   name="RetailPrice"
                   value=""
                   class="form-control"
                   placeholder="Prijs, bijvoorbeeld 12,50"
                   required="required"
                   pattern="[0-9,.]+" />
        }

        @Html.ValidationMessageFor(m => m.RetailPrice, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Voorraad</label>

        <input type="number"
               name="Stock"
               value="@Model.Stock"
               class="form-control"
               placeholder="Voorraad"
               min="0"
               required="required" />

        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label for="categorySelect" class="form-label">Categorie</label>

        <select id="categorySelect" name="CategoryID" class="form-select" required="required">
            <option value="">Selecteer categorie</option>

            @foreach (var category in categories)
            {
                if (Model.CategoryID == category.CategoryID)
                {
                    <option value="@category.CategoryID"
                            data-cardid="@category.MenuCardID"
                            selected="selected">
                        @GetCategoryDisplayName(category)
                    </option>
                }
                else
                {
                    <option value="@category.CategoryID"
                            data-cardid="@category.MenuCardID">
                        @GetCategoryDisplayName(category)
                    </option>
                }
            }
        </select>

        @Html.ValidationMessageFor(m => m.CategoryID, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <div class="form-check">
            <input type="checkbox"
                   id="isAlcoholicCheck"
                   name="IsAlcoholic"
                   class="form-check-input"
                   @(Model.IsAlcoholic ? "checked" : "") />
            <label for="isAlcoholicCheck" class="form-check-label">
                Alcoholische drank (21% VAT)
            </label>
        </div>
        <small class="text-muted d-block mt-1">
            Vink aan indien dit product alcoholhoudend is
        </small>
    </div>

    <div class="form-group mb-3">
        <label for="imageUpload" class="form-label">Afbeelding optioneel</label>

        <input type="file"
               id="imageUpload"
               name="imageFile"
               accept="image/*"
               class="form-control" />

        @if (isEdit && !string.IsNullOrWhiteSpace(Model.ImagePath))
        {
            <div class="mt-2">
                <img src="@Model.ImagePath"
                     alt="@Model.Name"
                     style="max-width: 150px; max-height: 150px; border-radius: 6px;" />

                <div class="small text-muted mt-2">Huidige afbeelding</div>
            </div>
        }

        <small class="form-text text-muted">
            JPG, PNG of WebP. Maximaal 10MB.
        </small>
    </div>

    @if (!isEdit)
    {
        <input type="hidden" name="IsActive" value="true" />
    }

    <div class="form-actions">
        <button type="submit" class="btn btn-primary preserve-scroll">
            @buttonText
        </button>

        <a href="@Url.Action("Index", "ManageMenu", new { search = searchValue })"
               class="btn btn-secondary preserve-scroll">
            Annuleren
        </a>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const cardSelect = document.getElementById('menuCardSelect');
        const categorySelect = document.getElementById('categorySelect');
        const form = document.getElementById('menuItemEditCreateForm');

        function filterCategories() {
            if (!cardSelect || !categorySelect) {
                return;
            }

            const selectedCardId = cardSelect.value;

            Array.from(categorySelect.options).forEach(function (option) {
                if (option.value === '') {
                    option.hidden = false;
                    return;
                }

                const optionCardId = option.getAttribute('data-cardid');

                if (!selectedCardId) {
                    option.hidden = false;
                    return;
                }

                option.hidden = optionCardId !== selectedCardId;
            });

            const selectedOption = categorySelect.options[categorySelect.selectedIndex];

            if (selectedOption && selectedOption.hidden) {
                categorySelect.value = '';
            }
        }

        if (cardSelect && categorySelect) {
            filterCategories();

            cardSelect.addEventListener('change', function () {
                categorySelect.value = '';
                filterCategories();
            });
        }

        if (form) {
            form.addEventListener('submit', function (e) {
                if (!categorySelect || !categorySelect.value) {
                    alert('Selecteer een geldige categorie.');
                    e.preventDefault();
                    return false;
                }

                if (!cardSelect) {
                    return true;
                }

                const selectedOption = categorySelect.options[categorySelect.selectedIndex];

                if (selectedOption) {
                    const optionCardId = selectedOption.getAttribute('data-cardid');

                    if (optionCardId !== cardSelect.value) {
                        alert('De geselecteerde categorie hoort niet bij deze kaart.');
                        e.preventDefault();
                        return false;
                    }
                }
            });
        }
    });
</script>