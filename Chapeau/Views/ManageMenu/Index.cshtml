@model Chapeau.ViewModels.MenuManagementViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Menu Beheer";
    CultureInfo culture = CultureInfo.GetCultureInfo("nl-NL");
}

<div class="page-content">
    <div class="page-title-row">
        <h2 class="page-title">Menu Beheer</h2>
        @if (Model.ShowCreate)
        {
            <a asp-action="Index" asp-route-cardId="@Model.SelectedCardId"
               asp-route-categoryId="@Model.SelectedCategoryId"
               class="btn-close-form preserve-scroll">Sluiten</a>
        }
        else
        {
            <a asp-action="Index" asp-route-showCreate="true" asp-route-cardId="@Model.SelectedCardId"
               asp-route-categoryId="@Model.SelectedCategoryId"
               class="btn-new preserve-scroll">+ Nieuw Item</a>
        }
    </div>

    <form id="manageMenuFilterForm" asp-action="Index" method="get" class="preserve-scroll-form">
        <div class="filter-row">
            <div class="filter-group">
                <label for="cardFilter">Kaart</label>
                <select id="cardFilter" name="cardId">
                    <option value="">Alle</option>
                    @foreach (var card in Model.MenuCards)
                    {
                        <option value="@card.MenuCardID" selected="@(Model.SelectedCardId == card.MenuCardID)">@card.Name</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label for="categoryFilter">Categorie</label>
                <select id="categoryFilter" name="categoryId">
                    <option value="">Alle</option>
                    @foreach (var category in Model.FilterCategories)
                    {
                        <option value="@category.CategoryID" selected="@(Model.SelectedCategoryId == category.CategoryID)">
                            @category.DisplayName
                        </option>
                    }
                </select>
            </div>
        </div>
    </form>

    @if (Model.ShowCreate)
    {
        <partial name="_MenuItemForm" model="Model" />
    }

    <div class="menu-table-card">
        <table class="menu-table">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Prijs</th>
                    <th>Kaart</th>
                    <th>Categorie</th>
                    <th>Status</th>
                    <th>Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.MenuItems)
                {
                    <tr class="@(!item.IsActive ? "inactive-row" : string.Empty)">
                        <td>@item.Name</td>
                        <td>€ @item.RetailPrice.ToString("F2", culture)</td>
                        <td>@item.Category.MenuCardName</td>
                        <td>@item.Category.DisplayName</td>
                        <td>
                            <span class="status-badge @(item.IsActive ? "status-active" : "status-inactive")">
                                @(item.IsActive ? "Actief" : "Inactief")
                            </span>
                        </td>
                        <td>
                            <div class="action-cell">
                                <a asp-action="Index" asp-route-editId="@item.MenuItemID"
                                   asp-route-cardId="@Model.SelectedCardId" asp-route-categoryId="@Model.SelectedCategoryId"
                                   class="action-icon action-edit preserve-scroll" title="Bewerken">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 7.125L16.875 4.5" />
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                    </svg>
                                </a>
                                <form asp-action="ToggleActive" method="post" class="inline-action-form preserve-scroll-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.MenuItemID" />
                                    <input type="hidden" name="cardId" value="@Model.SelectedCardId" />
                                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                    @if (item.IsActive)
                                    {
                                        <input type="hidden" name="active" value="false" />
                                        <button type="submit" class="action-icon action-inactive preserve-scroll" title="Deactiveren">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v9" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                            </svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <input type="hidden" name="active" value="true" />
                                        <button type="submit" class="action-icon action-active preserve-scroll" title="Activeren">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v9" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75a7.5 7.5 0 1010.5 0" />
                                            </svg>
                                        </button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                    @if (Model.EditItem?.MenuItemID == item.MenuItemID)
                    {
                        <tr class="edit-row">
                            <td colspan="6">
                                <partial name="_MenuItemForm" model="Model" />
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/manage-menu.js" asp-append-version="true"></script>
}
