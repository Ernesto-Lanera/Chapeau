@model Chapeau.Models.MenuItem

<h2>Edit Menu Item</h2>

<form method="post" action="@Url.Action("Edit")">
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <input type="hidden" name="MenuItemID" value="@Model.MenuItemID" />

    <div class="form-group mb-3">
        <label>Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Price</label>
        <input type="number" step="any" name="Price" value="@Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Stock</label>
        <input type="number" name="Stock" value="@Model.Stock" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Category</label>
        <select name="CategoryID" class="form-select" required>
            @{
                var categories = (System.Collections.Generic.IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Categories;
                var selectedCategory = categories?.FirstOrDefault(c => c.Selected);
                if (selectedCategory != null)
                {
                    <option value="@selectedCategory.Value" selected="selected">@selectedCategory.Text</option>
                }
            }
            <option value="">-- Select a Category --</option>
            @foreach(var category in ViewBag.Categories)
            {
                if (!category.Selected)
                {
                    <option value="@category.Value">@category.Text</option>
                }
            }
        </select>
        @Html.ValidationMessageFor(m => m.CategoryID, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") /> Is Active
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
</form>