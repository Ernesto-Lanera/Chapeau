@model IEnumerable<Chapeau.Models.MenuItem>

<div class="container-fluid d-flex flex-column overflow-hidden bg-light p-0" style="height: calc(100vh - 75px);">

    <div class="d-flex align-items-center bg-white border-bottom p-2 shadow-sm z-1 m-0 flex-shrink-0">
        <div class="d-flex align-items-center gap-3 overflow-x-auto text-nowrap w-100 hide-scrollbar">

            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-primary px-3 filter-btn active" data-filter="all">All</button>

                @if (ViewBag.MenuCards != null)
                {
                    @foreach (var menuCard in ViewBag.MenuCards)
                    {
                        <button class="btn btn-sm btn-outline-primary px-3 filter-btn"
                                data-filter="menucard"
                                data-value="@menuCard.Value.ToString()">
                            @menuCard.Text
                        </button>
                    }
                }
            </div>

@*             <div class="d-flex gap-2 flex-shrink-0 border-start ps-3">
                <button class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                        <path d="M3 3h7v7H3V3zm11 0h7v7h-7V3zm0 11h7v7h-7v-7zM3 14h7v7H3v-7z" />
                    </svg>
                </button>
                <button class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                        <path d="M3 5h18v2H3V5zm0 6h18v2H3v-2zm0 6h18v2H3v-2z" />
                    </svg>
                </button>
            </div> *@

        </div>
    </div>

    <div class="d-flex flex-row flex-grow-1 overflow-hidden w-100">

        <div class="col-2 bg-white border-end p-2 h-100 overflow-y-auto hide-scrollbar">
            <h6 class="text-muted mb-2 d-none d-md-block small">Filters</h6>
            <div class="d-flex flex-column gap-2 pb-5">

                @if (ViewBag.AllCategories != null)
                {
                    @foreach (var category in ViewBag.AllCategories)
                    {
                        <button class="btn btn-sm btn-outline-secondary text-start w-100 text-wrap flex-shrink-0 filter-btn"
                                data-filter="category"
                                data-value="@category.CategoryID">
                            @category.Name
                        </button>
                    }
                }

            </div>
        </div>

        <div class="col-7 p-2 p-md-3 h-100 overflow-y-auto hide-scrollbar">
            <div class="row row-cols-2 row-cols-xl-3 g-2 g-md-3 pb-5" id="menuGrid">

                @foreach (var item in Model)
                {
                    string stockClasses = "border-success border-2";

                    if (item.Stock == 0)
                    {
                        stockClasses = "border-danger border-2 bg-light opacity-50";
                    }
                    else if (item.Stock <= 10)
                    {
                        stockClasses = "border-warning border-2";
                    }

                    <div class="col menu-item" data-category="@item.Category?.CategoryID" data-menucard="@item.Category?.MenuCardID">

                        <div class="card h-100 shadow-sm @stockClasses" style="min-height: 160px;">

                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img class="card-img-top @(item.Stock == 0 ? "style-grayscale" : "")"
                                     src="@item.ImagePath" alt="@item.Name" loading="lazy"
                                     style="height: 100px; object-fit: cover; @(item.Stock == 0 ? "filter: grayscale(100%);" : "")" />
                            }

                            <div class="card-body d-flex flex-column justify-content-center align-items-center p-2 text-center">
                                <h6 class="card-title fw-bold mb-1" style="font-size: 0.95rem; line-height: 1.2;">@item.Name</h6>
                                <p class="card-text mb-0 small">@item.RetailPrice &euro;</p>

                                @if (item.Stock == 0)
                                {
                                    <span class="badge bg-danger mt-auto" style="font-size: 0.75rem;">Out of Stock</span>
                                }
                                else if (item.Stock <= 10)
                                {
                                    <span class="badge bg-warning text-dark mt-auto" style="font-size: 0.75rem;">Only @item.Stock left</span>
                                }
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

        <div class="col-3 bg-white border-start p-2 d-flex flex-column h-100 z-2 shadow-sm">
            <div class="flex-shrink-0 d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                <h4 class="mb-0 fw-bold fs-5">Tafel 1</h4>
            </div>

            <div class="flex-grow-1 overflow-y-auto hide-scrollbar">
                <p class="text-muted text-center mt-5 small">Select items to add to order...</p>
            </div>

            <div class="flex-shrink-0 mt-auto pt-2 pb-2 border-top d-flex flex-column gap-2">
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-danger fw-bold py-2 flex-grow-1">Cancel</button>
                    <button class="btn btn-sm btn-warning fw-bold py-2 flex-grow-1">Note</button>
                </div>
                <button class="btn btn-success fw-bold py-2 fs-6">Send to production</button>
            </div>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const filterButtons = document.querySelectorAll('.filter-btn');
        const menuItems = document.querySelectorAll('.menu-item');

        filterButtons.forEach(button => {
            button.addEventListener('click', function () {

                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const filterType = this.getAttribute('data-filter');
                const filterValue = this.getAttribute('data-value');

                menuItems.forEach(item => {
                    if (filterType === 'all') {
                        item.classList.remove('d-none');
                    } else {
                        const itemValue = item.getAttribute(`data-${filterType}`);

                        if (itemValue?.toString() === filterValue?.toString()) {
                            item.classList.remove('d-none');
                        } else {
                            item.classList.add('d-none');
                        }
                    }
                });
            });
        });
    });
</script>