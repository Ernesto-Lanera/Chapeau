@model IEnumerable<Chapeau.Models.MenuItem>

<link rel="stylesheet" href="~/css/menu.css" />

<div class="container-fluid d-flex flex-column overflow-hidden p-0 menu-main-container">

    <div class="d-flex align-items-center p-2 shadow-sm z-1 m-0 flex-shrink-0 menu-top-bar">
        <div class="d-flex align-items-center gap-3 overflow-x-auto text-nowrap w-100 hide-scrollbar">
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-primary px-3 filter-btn menucard-btn active" data-filter="all">All</button>

                @if (ViewBag.MenuCards != null)
                {
                    @foreach (var menuCard in ViewBag.MenuCards)
                    {
                        <button class="btn btn-sm btn-outline-primary px-3 filter-btn menucard-btn"
                                data-filter="menucard"
                                data-value="@menuCard.Value.ToString()">
                            @menuCard.Text
                        </button>
                    }
                }
            </div>
        </div>
    </div>

    <div class="d-flex flex-row flex-grow-1 overflow-hidden w-100">

        <div class="col-2 p-2 h-100 overflow-y-auto hide-scrollbar menu-sidebar">
            <h6 class="mb-2 d-none d-md-block small menu-text-muted">Filters</h6>
            <div class="d-flex flex-column gap-2 pb-5">
                @if (ViewBag.AllCategories != null)
                {
                    @foreach (var category in ViewBag.AllCategories)
                    {
                        <button class="btn btn-sm btn-outline-secondary text-start w-100 text-wrap flex-shrink-0 filter-btn category-btn"
                                data-filter="category"
                                data-value="@category.CategoryID"
                                data-menucard="@category.MenuCardID">
                            @category.Name
                        </button>
                    }
                }
            </div>
        </div>

        <div class="col-7 p-2 p-md-3 h-100 overflow-y-auto hide-scrollbar">
            <div class="row row-cols-2 row-cols-xl-3 g-2 g-md-3 pb-5" id="menuGrid">
                @foreach (var item in Model)
                {
                    @if (item.IsActive)
                    {

                        
                        string stockClasses = "menu-stock-normal";

                        if (item.IsOutOfStock)
                        {
                            stockClasses = "menu-stock-empty";
                        }
                        else if (item.IsAlmostOutOfStock)
                        {
                            stockClasses = "menu-stock-low";
                        }

                        <div class="col menu-item" data-category="@item.Category?.CategoryID" data-menucard="@item.Category?.MenuCardID">

                            <input type="hidden" name="MenuItemId" value="@item.MenuItemID" />
                            <input type="hidden" name="MenuItemName" value="@item.Name" />

                            <div class="card h-100 shadow-sm menu-item-card @stockClasses" onclick="addToOrder(@item.MenuItemID, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.Name))')">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img class="card-img-top menu-item-img @(item.Stock == 0 ? "out-of-stock-img style-grayscale" : "")"
                                         src="@item.ImagePath"
                                         alt="@item.Name"
                                         loading="lazy" />
                                }

                                <div class="card-body d-flex flex-column justify-content-center align-items-center p-2 text-center">
                                    <h6 class="card-title fw-bold mb-1 menu-item-title">@item.Name</h6>
                                    <p class="card-text mb-0 small">@item.RetailPrice &euro;</p>

                                    @if (item.Stock == 0)
                                    {
                                        <span class="badge bg-danger mt-auto stock-badge">Out of Stock</span>
                                    }
                                    else if (item.Stock <= 10)
                                    {
                                        <span class="badge bg-warning text-dark mt-auto stock-badge">Only @item.Stock left</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-3 bg-white border-start p-2 d-flex flex-column h-100 z-2 shadow-sm">
            <div class="flex-shrink-0 d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                <h4 class="mb-0 fw-bold fs-5">Tafel @(ViewBag.TableNumber ?? "?")</h4>
            </div>

            <div id="cart-container" class="flex-grow-1 overflow-y-auto hide-scrollbar">
            </div>

            <div class="mt-auto d-flex justify-content-between pt-3 menu-border-top">
                <button class="btn btn-danger w-50 me-1 fw-bold rounded-3">Cancel</button>
                <form method="post" asp-controller="Menu" asp-action="SaveOrderToDb" class="w-50 ms-1">
                    <button class="btn btn-primary w-100 fw-bold rounded-3" type="submit">Send To Kitchen</button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        window.stockLevels = {
            @foreach (var item in Model)
            {
                        @:@item.MenuItemID: @item.Stock,
            }
        };
    </script>

    <script src="~/js/MenuFilter.js"></script>
    <script src="~/js/Order.js"></script>
}