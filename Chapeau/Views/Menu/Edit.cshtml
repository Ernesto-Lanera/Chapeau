@model Chapeau.Models.MenuItem

<h2>Edit Menu Item</h2>

<form method="post" action="@Url.Action("Edit")">
    <input type="hidden" name="MenuItemID" value="@Model.MenuItemID" />

    <div class="form-group mb-3">
        <label>Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" required />
    </div>
    <div class="form-group mb-3">
        <label>Price</label>
        <input type="number" step="any" name="Price" value="@Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-control" required />
    </div>
    <div class="form-group mb-3">
        <label>Stock</label>
        <input type="number" name="Stock" value="@Model.Stock" class="form-control" required />
    </div>
    <div class="form-group mb-3">
        <label>Category</label>
        <select name="CategoryID" class="form-control" required>
            <option value="">-- Select Category --</option>
            @foreach(var category in ViewBag.Categories)
            {
                if(Model.CategoryID == category.CategoryID)
                {
                    <option value="@category.CategoryID" selected>@category.Name</option>
                }
                else
                {
                    <option value="@category.CategoryID">@category.Name</option>
                }
            }
        </select>
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") /> Is Active
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
</form>