@model Chapeau.Models.MenuItem

<h2>Menu-item bewerken</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Er gaat iets mis</strong>
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                if (!string.IsNullOrEmpty(error.ErrorMessage))
                {
                    <li>@error.ErrorMessage</li>
                }
            }
        </ul>
    </div>
}

<form method="post" action="@Url.Action("Edit")">

    <input type="hidden" name="MenuItemID" value="@Model.MenuItemID" />

    <div class="form-group mb-3">
        <label class="form-label">Kaart *</label>
        <select id="editCardSelect" class="form-select" required disabled>
            @if (ViewBag.MenuCards != null && Model.Category != null)
            {
                foreach(var card in ViewBag.MenuCards)
                {
                    var isSelected = card.Value == Model.Category.MenuCardID.ToString();
                    if (isSelected)
                    {
                        <option value="@card.Value" selected>@card.Text</option>
                    }
                }
            }
        </select>
        <small class="text-muted">Kaart kan niet worden gewijzigd (bepaald door huidige categorie)</small>
    </div>

    <div class="form-group mb-3">
        <label>Naam</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Inkoopprijs</label>
        <input type="number" step="any" name="PurchasePrice" value="@Model.PurchasePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.PurchasePrice, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Verkoopprijs</label>
        <input type="number" step="any" name="RetailPrice" value="@Model.RetailPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.RetailPrice, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Voorraad</label>
        <input type="number" name="Stock" value="@Model.Stock" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label for="editCategorySelect" class="form-label">Categorie</label>
        <select id="editCategorySelect" name="CategoryID" class="form-select" required>
            @foreach(var category in ViewBag.Categories as IEnumerable<Chapeau.Models.Category> ?? Enumerable.Empty<Chapeau.Models.Category>())
            {
                if (Model.CategoryID == category.CategoryID)
                {
                    <option value="@category.CategoryID" data-cardid="@category.MenuCardID" selected>@category.Name</option>
                }
                else
                {
                    <option value="@category.CategoryID" data-cardid="@category.MenuCardID">@category.Name</option>
                }
            }
        </select>
        <span class="text-danger">@Html.ValidationMessageFor(m => m.CategoryID)</span>
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="hidden" name="IsActive" value="false" />
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") /> Actief
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Bijwerken</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Annuleren</a>
</form>