@model Chapeau.Models.MenuItem

<h2>Nieuw menu-item toevoegen</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form method="post" action="@Url.Action("Create")">
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group mb-3">
        <label>Naam</label>
        <input type="text" name="Name" value="@Model?.Name" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Inkoopprijs</label>
        <input type="number" step="any" name="PurchasePrice" value="@Model?.PurchasePrice" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.PurchasePrice, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Verkoopprijs</label>
        <input type="number" step="any" name="RetailPrice" value="@Model?.RetailPrice" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.RetailPrice, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Voorraad</label>
        <input type="number" name="Stock" value="@Model?.Stock" class="form-control" min="0" required />
        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label asp-for="CategoryID" class="form-label">Categorie</label>
        <select name="CategoryID" class="form-select" required>
            @{
                var categories = (System.Collections.Generic.IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Categories;
                var selectedCategory = categories?.FirstOrDefault(c => c.Selected);
                if (selectedCategory != null)
                {
                    <option value="@selectedCategory.Value" selected="selected">@selectedCategory.Text</option>
                }
            }
            <option value="">-- Selecteer een categorie --</option>
            @foreach(var category in ViewBag.Categories)
            {
                if (!category.Selected)
                {
                    <option value="@category.Value">@category.Text</option>
                }
            }
        </select>
        <span asp-validation-for="CategoryID" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" name="IsActive" value="true" @(Model?.IsActive ?? true ? "checked" : "") /> Actief
        </label>
    </div>

    <button type="submit" class="btn btn-success">Opslaan</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Annuleren</a>
</form>