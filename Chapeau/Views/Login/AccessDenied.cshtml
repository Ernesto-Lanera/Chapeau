@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">Access Denied</h4>
                <p>You do not have permission to access this resource. Please contact an administrator if you believe this is an error.</p>
                <hr />
                <p class="mb-0">
                    <a asp-action="Index" asp-controller="Home" class="btn btn-primary">Return to Home</a>
                </p>
            </div>
        </div>
    </div>
</div>
