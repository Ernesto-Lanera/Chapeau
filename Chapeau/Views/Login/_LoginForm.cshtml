@model LoginViewModel

<form method="post" asp-action="Login" asp-controller="Account">
    <input type="hidden" asp-for="ReturnUrl" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Naam</label>
        <input asp-for="Name" class="form-control" placeholder="Vul uw volledige naam in" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Password" class="form-label">Wachtwoord</label>
        <input asp-for="Password" class="form-control" placeholder="Vul uw wachtwoord in" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary w-100">Inloggen</button>
</form>
