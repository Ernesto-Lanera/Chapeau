@model List<TableStatus>
@using System.Security.Claims
@using Chapeau.Constants.Login
@using Chapeau.Emums

@{
    ViewData["Title"] = "Tables Overview";
    Layout = "_Layout";

    var roleName = User.FindFirst(ClaimTypeConstants.RoleName)?.Value
                   ?? User.FindFirst(ClaimsIdentity.DefaultRoleClaimType)?.Value
                   ?? "";
    var employeeName = User.FindFirst(ClaimTypeConstants.EmployeeName)?.Value
                       ?? User.FindFirst(ClaimsIdentity.DefaultNameClaimType)?.Value
                       ?? User.Identity?.Name
                       ?? "User";

    var sortedTables = Model.OrderBy(t => t.TableNumber).ToList();

    var sidebarTables = Model
        .Where(t => t.IsOccupied)
        .OrderBy(t => t.Orders.Count > 0 ? t.Orders.Min(o => o.OrderDate) : DateTime.MaxValue)
        .ThenBy(t => t.TableNumber)
        .ToList();
}

@functions {
    string GetSidebarStatus(TableStatus table)
    {
        if (table.Orders.Any(o => o.OrderStatus == OrderStatus.Ordered))
            return "Ordered";
        return "Prepared";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Table_Overview/globals.css">
    <link rel="stylesheet" href="~/css/Table_Overview/styleguide.css">
    <link rel="stylesheet" href="~/css/Table_Overview/style.css">
}

<div class="final-table-overview">

<div class="frame">
<aside class="menu" aria-label="Ordered and prepared tables">
<div class="table-sidebar-header">Orders</div>
@for (int i = 0; i < sidebarTables.Count; i++)
{
    var table = sidebarTables[i];
    var status = GetSidebarStatus(table);
    <section class="table-ordered" aria-labelledby="sidebar-table-@table.TableId">
        <div class="rectangle" aria-hidden="true"></div>
        <div class="ordered">
            <div class="title" id="sidebar-table-@table.TableId">@status</div>
        </div>
        <h2 class="div">Table @table.TableNumber</h2>
        <div class="rectangle-2" aria-hidden="true"></div>
        <div class="text-wrapper-2">Occupied</div>
        <a href="/Menu/Index?tableId=@table.TableId&tableNumber=@table.TableNumber" class="sidebar-btn sidebar-btn-edit" aria-label="Edit Table @table.TableNumber order">
            <span class="sidebar-btn-text sidebar-btn-text-edit">Edit</span>
        </a>
        <form method="post" asp-action="MarkTableServed" asp-controller="Table" class="sidebar-btn sidebar-btn-served" aria-label="Mark Table @table.TableNumber as served">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tableId" value="@table.TableId" />
            <button class="sidebar-btn-inner" type="submit">
                <span class="sidebar-btn-text sidebar-btn-text-served">Served</span>
            </button>
        </form>
        <form method="post" asp-action="ToggleStatus" asp-controller="Table" class="sidebar-btn sidebar-btn-free" aria-label="Free Table @table.TableNumber">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tableId" value="@table.TableId" />
            <input type="hidden" name="occupied" value="false" />
            <button class="sidebar-btn-inner" type="submit">
                <span class="sidebar-btn-text sidebar-btn-text-free">Free</span>
            </button>
        </form>
    </section>
}
</aside>

<div class="main-area">
<div class="table-grid">
@for (int i = 0; i < sortedTables.Count; i++)
{
    var table = sortedTables[i];

    if (table.IsOccupied)
    {
        <div class="table-cell">
        <form method="get" action="/Menu/Index">
            <input type="hidden" name="tableId" value="@table.TableId" />
            <input type="hidden" name="tableNumber" value="@table.TableNumber" />
            <button class="occupied-table" type="submit" aria-label="Occupied Table @table.TableNumber">
                <span class="table">Table @table.TableNumber</span>
                <div class="rectangle-12" aria-hidden="true"></div>
                <div class="rectangle-13" aria-hidden="true"></div>
                <div class="rectangle-14" aria-hidden="true"></div>
                <div class="rectangle-15" aria-hidden="true"></div>
            </button>
        </form>
        </div>
    }
    else
    {
        <div class="table-cell">
        <form method="post" asp-action="ToggleStatus" asp-controller="Table"
              id="available-form-@table.TableId">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tableId" value="@table.TableId" />
            <input type="hidden" name="occupied" value="true" />
            <input type="hidden" name="returnUrl" value="/Menu/Index?tableId=@table.TableId&amp;tableNumber=@table.TableNumber" />
            <input type="hidden" name="guestNames" id="guest-names-@table.TableId" value="" />
            <button class="available-table" type="button" aria-label="Available Table @table.TableNumber"
                    onclick="openGuestModal(@table.TableId, @table.TableNumber)">
                <div class="rectangle-8" aria-hidden="true"></div>
                <div class="rectangle-9" aria-hidden="true"></div>
                <div class="rectangle-10" aria-hidden="true"></div>
                <div class="rectangle-11" aria-hidden="true"></div>
                <div class="rectangle-6" aria-hidden="true"></div>
                <span class="text-wrapper-6">Table @table.TableNumber</span>
            </button>
        </form>
        </div>
    }
}
</div>
</div>
</div>
</div>

<div id="guest-modal" class="guest-modal-overlay">
    <div class="guest-modal-content">
        <h3 class="guest-modal-title">Aantal gasten</h3>
        <p class="guest-modal-text">Wat is het aantal gasten voor deze tafel?</p>
        <div class="guest-options-row">
            <button type="button" onclick="setGuestCount(1)" class="guest-option-btn guest-option">1</button>
            <button type="button" onclick="setGuestCount(2)" class="guest-option-btn guest-option selected">2</button>
            <button type="button" onclick="setGuestCount(3)" class="guest-option-btn guest-option">3</button>
            <button type="button" onclick="setGuestCount(4)" class="guest-option-btn guest-option">4</button>
        </div>
        <input type="hidden" id="selected-guests" value="2" />
        <div id="guest-name-fields" class="guest-name-fields"></div>
        <div class="guest-modal-actions">
            <button type="button" onclick="closeGuestModal()" class="guest-modal-btn guest-modal-btn-cancel">Annuleren</button>
            <button type="button" onclick="confirmGuest()" class="guest-modal-btn guest-modal-btn-save">Opslaan</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
var currentTableId = 0;

function openGuestModal(tableId, tableNumber) {
    currentTableId = tableId;
    document.getElementById('selected-guests').value = 2;
    var options = document.querySelectorAll('.guest-option');
    options.forEach(function(btn) {
        btn.classList.remove('selected');
    });
    options[1].classList.add('selected');
    document.getElementById('guest-modal').classList.add('show');
    renderGuestNameFields(2);
}

function closeGuestModal() {
    document.getElementById('guest-modal').classList.remove('show');
}

function setGuestCount(count) {
    document.getElementById('selected-guests').value = count;
    var options = document.querySelectorAll('.guest-option');
    options.forEach(function(btn, index) {
        if (index + 1 === count) {
            btn.classList.add('selected');
        } else {
            btn.classList.remove('selected');
        }
    });
    renderGuestNameFields(count);
}

function renderGuestNameFields(count) {
    var container = document.getElementById('guest-name-fields');
    var html = '';
    for (var i = 1; i <= count; i++) {
        html += '<div class="guest-field-container">' +
            '<label class="guest-field-label" for="guest-name-' + i + '">Gast ' + i + '</label>' +
            '<input type="text" id="guest-name-' + i + '" class="guest-field-input" placeholder="Naam gast ' + i + '" />' +
            '</div>';
    }
    container.innerHTML = html;
    var firstInput = document.getElementById('guest-name-1');
    if (firstInput) firstInput.focus();
}

function confirmGuest() {
    if (currentTableId === 0) return;
    var count = parseInt(document.getElementById('selected-guests').value);
    var names = [];
    for (var i = 1; i <= count; i++) {
        var input = document.getElementById('guest-name-' + i);
        var name = input ? input.value.trim() : '';
        names.push(name || 'Gast ' + i);
    }
    document.getElementById('guest-names-' + currentTableId).value = names.join(', ');
    closeGuestModal();
    var form = document.getElementById('available-form-' + currentTableId);
    if (form) {
        form.submit();
    }
}
</script>
}
